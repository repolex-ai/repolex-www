@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix ast-x: <https://repolex.ai/ontology/repolex/ast-extension/> .
@prefix lsp: <https://repolex.ai/ontology/extracts/microsoft/multilspy/v0.0.15/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Tree-sitter language namespaces (v0.25)
@prefix cpp:        <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/cpp/> .
@prefix csharp:     <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/csharp/> .
@prefix dart:       <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/dart/> .
@prefix go:         <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/go/> .
@prefix java:       <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/java/> .
@prefix javascript: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/javascript/> .
@prefix kotlin:     <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/kotlin/> .
@prefix python:     <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/python/> .
@prefix ruby:       <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/ruby/> .
@prefix rust:       <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/rust/> .
@prefix scala:      <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/scala/> .
@prefix swift:      <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/swift/> .
@prefix typescript: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/typescript/> .

# =============================================================================
# AST EXTENSION ONTOLOGY
# =============================================================================
# Universal AST types and one-off AST properties for cross-language analysis.
#
# This ontology maps language-specific tree-sitter node types to generic
# ast-x: classes via rdfs:subClassOf, enabling cross-language SPARQL queries.
#
# Organization:
#   1. One-off AST properties (SCM-extracted, etc.)
#   2. Universal AST type definitions (control flow, dataflow, LSP)
#   3. Language-specific subclass mappings (by language)
#
# Languages covered (multilspy supported):
#   C++, C#, Dart, Go, Java, JavaScript, Kotlin, Python, Ruby, Rust, TypeScript
# =============================================================================

<https://repolex.ai/ontology/repolex/ast-extension> a owl:Ontology ;
    rdfs:label "AST Extension Ontology" ;
    rdfs:comment "Universal AST types and extensions for cross-language analysis. Maps language-specific tree-sitter nodes to generic ast-x: classes via rdfs:subClassOf." ;
    owl:versionInfo "1.0" .


# =============================================================================
# ONE-OFF AST PROPERTIES
# =============================================================================
# Properties that don't fit the subclassing pattern but are needed for AST analysis.
# =============================================================================

ast-x:resolutionNode a owl:ObjectProperty ;
    rdfs:label "resolution node" ;
    rdfs:comment "Points from an import statement to the specific child node containing the module/symbol name, extracted via tree-sitter .scm query at blob parse time. The child node has the correct position for LSP resolution." ;
    rdfs:range ast:Node .

ast-x:filePath a owl:DatatypeProperty ;
    rdfs:label "file path" ;
    rdfs:comment "Repository-relative file path for this AST node (e.g., 'src/main.js', 'lib/utils/helper.py'). Used to locate the source file within the repository structure." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

ast-x:sourceBlobNode a owl:ObjectProperty ;
    rdfs:label "source blob node" ;
    rdfs:comment "Points to the blob node that contains this AST node's source code. Links AST nodes back to their containing blob for retrieval and reference (e.g., <blob/abc123#node_42_1_50_2>)." ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Node .

ast-x:assignsTo a owl:DatatypeProperty ;
    rdfs:label "assigns to" ;
    rdfs:comment "Target variable name for assignment operations. Extracted from the left-hand side (field_left) of assignment nodes during blob parsing. For simple assignments only; complex targets (destructuring, field access) require following the assignment structure." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

ast-x:parameterIndex a owl:DatatypeProperty ;
    rdfs:label "parameter index" ;
    rdfs:comment "Zero-indexed position of this parameter in the function signature. Computed during AST traversal by counting parameter positions. Used for argument-to-parameter dataflow mapping." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:isOptional a owl:DatatypeProperty ;
    rdfs:label "is optional" ;
    rdfs:comment "Whether this parameter is optional/has a default value. Detected via .scm queries looking for: TypeScript '?' suffix, Python/Kotlin default values, etc. Populated during blob parsing." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

ast-x:docstring a owl:DatatypeProperty ;
    rdfs:label "docstring" ;
    rdfs:comment "Documentation text attached to a function, class, or module. Extracted from the first ast-x:Comment child of an ast-x:FunctionDefinition or ast-x:ClassDefinition during parse time. Used for documentation coverage analysis and LLM context." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .


# =============================================================================
# UNIVERSAL CONTROL FLOW TYPES
# =============================================================================
# Generic control flow constructs for cross-language analysis.
# =============================================================================

ast-x:IfStatement a owl:Class ;
    rdfs:label "if statement" ;
    rdfs:comment "Conditional branch: if, elif, unless, guard, if-modifier. Each represents a decision point for cyclomatic complexity." .

ast-x:ElseClause a owl:Class ;
    rdfs:label "else clause" ;
    rdfs:comment "Default branch when no condition matches. NOT a decision point - does not contribute to cyclomatic complexity. Separated from ast-x:IfStatement to avoid inflating complexity counts." .

ast-x:ForStatement a owl:Class ;
    rdfs:label "for statement" ;
    rdfs:comment "For loop: for-in, for-each, enhanced-for, range-based for. Iterator-driven." .

ast-x:WhileStatement a owl:Class ;
    rdfs:label "while statement" ;
    rdfs:comment "Condition-driven loop: while, do-while, loop (Rust), until (Ruby)." .

ast-x:SwitchStatement a owl:Class ;
    rdfs:label "switch statement" ;
    rdfs:comment "Multi-way dispatch: switch, match, case, when." .

ast-x:BreakStatement a owl:Class ;
    rdfs:label "break statement" ;
    rdfs:comment "Early exit: break (exits loop or switch), fallthrough (Go)." .

ast-x:ContinueStatement a owl:Class ;
    rdfs:label "continue statement" ;
    rdfs:comment "Skip to next iteration: continue, next (Ruby), redo (Ruby)." .

ast-x:ReturnStatement a owl:Class ;
    rdfs:label "return statement" ;
    rdfs:comment "Exit function with optional value: return, co_return (C++20)." .

ast-x:ThrowStatement a owl:Class ;
    rdfs:label "throw statement" ;
    rdfs:comment "Raise an exception: throw, raise." .

ast-x:TryStatement a owl:Class ;
    rdfs:label "try statement" ;
    rdfs:comment "Exception handling scope: try, try-with-resources (Java), begin (Ruby)." .

ast-x:CatchClause a owl:Class ;
    rdfs:label "catch clause" ;
    rdfs:comment "Exception handler: catch, except, rescue." .

ast-x:YieldStatement a owl:Class ;
    rdfs:label "yield statement" ;
    rdfs:comment "Generator/coroutine yield: yield, yield_expression, co_yield." .


# =============================================================================
# UNIVERSAL DATAFLOW TYPES
# =============================================================================
# Generic dataflow constructs for tracking data movement and variable binding.
# =============================================================================

ast-x:Assignment a owl:Class ;
    rdfs:label "assignment" ;
    rdfs:comment "Direct value assignment: x = expr. Includes walrus operator := (Python), Go short_var_declaration." .

ast-x:AugmentedAssignment a owl:Class ;
    rdfs:label "augmented assignment" ;
    rdfs:comment "Compound assignment: +=, -=, *=, /=, etc. Reads and writes the same variable." .

ast-x:VariableDeclaration a owl:Class ;
    rdfs:label "variable declaration" ;
    rdfs:comment "Introduces a new variable binding: let, var, const, short_var_declaration (:= in Go)." .

ast-x:ParameterList a owl:Class ;
    rdfs:label "parameter list" ;
    rdfs:comment "Container node holding all parameters in a function/method signature. Use ast-x:parameterIndex on child ast-x:Parameter nodes to track position." .

ast-x:Parameter a owl:Class ;
    rdfs:label "parameter" ;
    rdfs:comment "Individual parameter within a function/method signature. Covers required, optional, typed, default, variadic, and destructured parameters. Children of an ast-x:ParameterList." .


# =============================================================================
# UNIVERSAL LSP TYPES
# =============================================================================
# Cross-language classes for LSP-based code analysis and symbol resolution.
# =============================================================================

ast-x:FunctionDefinition a owl:Class ;
    rdfs:label "function definition" ;
    rdfs:comment "Any function, method, constructor, lambda, or closure definition. Used by multilspy to find all references." .

ast-x:ClassDefinition a owl:Class ;
    rdfs:label "class definition" ;
    rdfs:comment "Any class, interface, struct, enum, trait, or module definition. Includes impl blocks (Rust) and type declarations (Go)." .

ast-x:CallSite a owl:Class ;
    rdfs:label "call site" ;
    rdfs:comment "Any function call, method call, or constructor invocation. PRIMARY input for multilspy: each call_site is sent as a DefinitionRequest to resolve the target." .

ast-x:ImportStatement a owl:Class ;
    rdfs:label "import statement" ;
    rdfs:comment "Any import, use, require, or include directive. Used by multilspy to resolve module paths and cross-file symbol origins." .

ast-x:Comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:comment "Any comment node in the AST: line comments, block comments, doc comments. Provides context for LLM analysis. Documentation content is available via LSP hover for doc comments." .


# =============================================================================
# UNIVERSAL INHERITANCE TYPES
# =============================================================================
# Generic inheritance constructs for OOP hierarchy analysis.
# =============================================================================

ast-x:ExtendsClause a owl:Class ;
    rdfs:label "extends clause" ;
    rdfs:comment "Superclass/parent class declaration. Single inheritance (Java, Ruby) or primary base class (C++, Python). Used to identify class hierarchies." .

ast-x:ImplementsClause a owl:Class ;
    rdfs:label "implements clause" ;
    rdfs:comment "Interface implementation declaration. Maps to implements (Java, TypeScript), trait bounds (Rust), protocols (Swift)." .

ast-x:InheritanceSpecifier a owl:Class ;
    rdfs:label "inheritance specifier" ;
    rdfs:comment "General inheritance/delegation declaration. Includes delegation (Kotlin), trait bounds (Rust), interface embedding (Go)." .


# =============================================================================
# C++ MAPPINGS
# =============================================================================

## Control Flow
cpp:if_statement        rdfs:subClassOf ast-x:IfStatement .
cpp:for_statement       rdfs:subClassOf ast-x:ForStatement .
cpp:for_range_loop      rdfs:subClassOf ast-x:ForStatement .
cpp:while_statement     rdfs:subClassOf ast-x:WhileStatement .
cpp:do_statement        rdfs:subClassOf ast-x:WhileStatement .
cpp:switch_statement    rdfs:subClassOf ast-x:SwitchStatement .
cpp:break_statement     rdfs:subClassOf ast-x:BreakStatement .
cpp:continue_statement  rdfs:subClassOf ast-x:ContinueStatement .
cpp:return_statement    rdfs:subClassOf ast-x:ReturnStatement .
cpp:co_return_statement rdfs:subClassOf ast-x:ReturnStatement .
cpp:throw_statement     rdfs:subClassOf ast-x:ThrowStatement .
cpp:try_statement       rdfs:subClassOf ast-x:TryStatement .
cpp:seh_try_statement   rdfs:subClassOf ast-x:TryStatement .
cpp:catch_clause        rdfs:subClassOf ast-x:CatchClause .
cpp:seh_except_clause   rdfs:subClassOf ast-x:CatchClause .
cpp:co_yield_statement  rdfs:subClassOf ast-x:YieldStatement .

## Dataflow
cpp:assignment_expression          rdfs:subClassOf ast-x:Assignment .
cpp:parameter_list                 rdfs:subClassOf ast-x:ParameterList .
cpp:parameter_declaration          rdfs:subClassOf ast-x:Parameter .
cpp:optional_parameter_declaration rdfs:subClassOf ast-x:Parameter .
cpp:variadic_parameter_declaration rdfs:subClassOf ast-x:Parameter .

## LSP
cpp:function_definition  rdfs:subClassOf ast-x:FunctionDefinition .
cpp:class_specifier      rdfs:subClassOf ast-x:ClassDefinition .
cpp:struct_specifier     rdfs:subClassOf ast-x:ClassDefinition .
cpp:call_expression      rdfs:subClassOf ast-x:CallSite .
cpp:preproc_include      rdfs:subClassOf ast-x:ImportStatement .

## Inheritance
cpp:base_class_clause    rdfs:subClassOf ast-x:ExtendsClause .

## Comments
cpp:comment              rdfs:subClassOf ast-x:Comment .


