ns1:prerelease a owl:DatatypeProperty ;
    rdfs:label "prerelease" ;
    rdfs:comment "Whether to identify the release as a prerelease or a full release." ;
    rdfs:domain ns1:Release ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "prerelease" ;
    ns1:required true .

ns1:privacy a owl:DatatypeProperty ;
    rdfs:label "privacy" ;
    rdfs:comment "The level of privacy this team should have" ;
    rdfs:domain ns1:Team,
        ns1:TeamFull ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "privacy" .

ns1:private a owl:DatatypeProperty ;
    rdfs:label "private" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "private" ;
    ns1:required true .

ns1:privateGists a owl:DatatypeProperty ;
    rdfs:label "privateGists" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "private_gists" .

ns1:publicGists a owl:DatatypeProperty ;
    rdfs:label "publicGists" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "public_gists" ;
    ns1:required true .

ns1:publicRepos a owl:DatatypeProperty ;
    rdfs:label "publicRepos" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "public_repos" ;
    ns1:required true .

ns1:publiclyLeaked a owl:DatatypeProperty ;
    rdfs:label "publiclyLeaked" ;
    rdfs:comment "Whether the detected secret was publicly leaked." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "publicly_leaked" .

ns1:publishedAt a owl:DatatypeProperty ;
    rdfs:label "publishedAt" ;
    rdfs:comment "The date and time of when the advisory was published, in ISO 8601 format." ;
    rdfs:domain ns1:GlobalAdvisory,
        ns1:Release,
        ns1:RepositoryAdvisory ;
    rdfs:range xsd:dateTime ;
    ns1:openApiPropertyName "published_at" ;
    ns1:required true .

ns1:publisher a owl:ObjectProperty ;
    rdfs:label "publisher" ;
    rdfs:comment "The publisher of the advisory." ;
    rdfs:domain ns1:RepositoryAdvisory ;
    rdfs:range ns1:User ;
    ns1:openApiPropertyName "publisher" .

ns1:pullRequestCreationPolicy a owl:DatatypeProperty ;
    rdfs:label "pullRequestCreationPolicy" ;
    rdfs:comment "The policy controlling who can create pull requests: all or collaborators_only." ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "pull_request_creation_policy" .

ns1:pullRequestReviewId a owl:DatatypeProperty ;
    rdfs:label "pullRequestReviewId" ;
    rdfs:comment "The ID of the pull request review to which the comment belongs." ;
    rdfs:domain ns1:PullRequestReviewComment ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "pull_request_review_id" ;
    ns1:required true .

ns1:pushProtectionBypassRequestComment a owl:DatatypeProperty ;
    rdfs:label "pushProtectionBypassRequestComment" ;
    rdfs:comment "An optional comment when requesting a push protection bypass." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "push_protection_bypass_request_comment" .

ns1:pushProtectionBypassRequestHtmlUrl a owl:DatatypeProperty ;
    rdfs:label "pushProtectionBypassRequestHtmlUrl" ;
    rdfs:comment "The URL to a push protection bypass request." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:anyURI ;
    ns1:openApiPropertyName "push_protection_bypass_request_html_url" .

ns1:pushProtectionBypassRequestReviewer a owl:ObjectProperty ;
    rdfs:label "pushProtectionBypassRequestReviewer" ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range ns1:User ;
    ns1:openApiPropertyName "push_protection_bypass_request_reviewer" .

ns1:pushProtectionBypassRequestReviewerComment a owl:DatatypeProperty ;
    rdfs:label "pushProtectionBypassRequestReviewerComment" ;
    rdfs:comment "An optional comment when reviewing a push protection bypass." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "push_protection_bypass_request_reviewer_comment" .

ns1:pushProtectionBypassed a owl:DatatypeProperty ;
    rdfs:label "pushProtectionBypassed" ;
    rdfs:comment "Whether push protection was bypassed for the detected secret." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "push_protection_bypassed" .

ns1:pushProtectionBypassedAt a owl:DatatypeProperty ;
    rdfs:label "pushProtectionBypassedAt" ;
    rdfs:comment "The time that push protection was bypassed in ISO 8601 format: `YYYY-MM-DDTHH:MM:SSZ`." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:dateTime ;
    ns1:openApiPropertyName "push_protection_bypassed_at" .

ns1:pushProtectionBypassedBy a owl:ObjectProperty ;
    rdfs:label "pushProtectionBypassedBy" ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range ns1:User ;
    ns1:openApiPropertyName "push_protection_bypassed_by" .

ns1:pushedAt a owl:DatatypeProperty ;
    rdfs:label "pushedAt" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:dateTime ;
    ns1:openApiPropertyName "pushed_at" ;
    ns1:required true .

ns1:reactions a owl:ObjectProperty ;
    rdfs:label "reactions" ;
    rdfs:domain ns1:Issue,
        ns1:IssueComment,
        ns1:PullRequestReviewComment,
        ns1:Release ;
    rdfs:range ns1:ReactionRollup ;
    ns1:openApiPropertyName "reactions" .

ns1:readersCanCreateDiscussions a owl:DatatypeProperty ;
    rdfs:label "readersCanCreateDiscussions" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "readers_can_create_discussions" .

ns1:rebaseable a owl:DatatypeProperty ;
    rdfs:label "rebaseable" ;
    rdfs:domain ns1:PullRequest ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "rebaseable" .

ns1:references a owl:DatatypeProperty ;
    rdfs:label "references" ;
    rdfs:domain ns1:GlobalAdvisory ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "references" .

ns1:reposCount a owl:DatatypeProperty ;
    rdfs:label "reposCount" ;
    rdfs:domain ns1:TeamFull ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "repos_count" ;
    ns1:required true .

ns1:repository a owl:ObjectProperty ;
    rdfs:label "repository" ;
    rdfs:domain ns1:Issue ;
    rdfs:range ns1:Repository ;
    ns1:openApiPropertyName "repository" .

ns1:repositoryAdvisoryUrl a owl:DatatypeProperty ;
    rdfs:label "repositoryAdvisoryUrl" ;
    rdfs:comment "The API URL for the repository advisory." ;
    rdfs:domain ns1:GlobalAdvisory ;
    rdfs:range xsd:anyURI ;
    ns1:openApiPropertyName "repository_advisory_url" ;
    ns1:required true .

ns1:requestedReviewers a owl:ObjectProperty ;
    rdfs:label "requestedReviewers" ;
    rdfs:domain ns1:PullRequest ;
    rdfs:range ns1:User ;
    ns1:openApiPropertyName "requested_reviewers" .

ns1:required a owl:AnnotationProperty ;
    rdfs:label "required" ;
    rdfs:comment "Whether this property is required per the OpenAPI spec" .

ns1:resolutionComment a owl:DatatypeProperty ;
    rdfs:label "resolutionComment" ;
    rdfs:comment "An optional comment to resolve an alert." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "resolution_comment" .

ns1:resolvedAt a owl:DatatypeProperty ;
    rdfs:label "resolvedAt" ;
    rdfs:comment "The time that the alert was resolved in ISO 8601 format: `YYYY-MM-DDTHH:MM:SSZ`." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:dateTime ;
    ns1:openApiPropertyName "resolved_at" .

ns1:resolvedBy a owl:ObjectProperty ;
    rdfs:label "resolvedBy" ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range ns1:User ;
    ns1:openApiPropertyName "resolved_by" .

ns1:reviewComments a owl:DatatypeProperty ;
    rdfs:label "reviewComments" ;
    rdfs:domain ns1:PullRequest ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "review_comments" ;
    ns1:required true .

ns1:rocket a owl:DatatypeProperty ;
    rdfs:label "rocket" ;
    rdfs:domain ns1:ReactionRollup ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "rocket" ;
    ns1:required true .

ns1:role a owl:DatatypeProperty ;
    rdfs:label "role" ;
    rdfs:comment "The user's membership type in the organization." ;
    rdfs:domain ns1:OrgMembership ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "role" ;
    ns1:required true .

ns1:secret a owl:DatatypeProperty ;
    rdfs:label "secret" ;
    rdfs:comment "The secret that was detected." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "secret" .

ns1:secretScanningEnabledForNewRepositories a owl:DatatypeProperty ;
    rdfs:label "secretScanningEnabledForNewRepositories" ;
    rdfs:comment """**Endpoint closing down notice.** Please use [code security configurations](https://docs.github.com/rest/code-security/configurations) instead.

Whether secret scanning is automatically enabled for new repositories and repositories transferred to this organization.

This field is only visible to organization owners or members of a team with the security manager role.""" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "secret_scanning_enabled_for_new_repositories" .

ns1:secretScanningPushProtectionCustomLink a owl:DatatypeProperty ;
    rdfs:label "secretScanningPushProtectionCustomLink" ;
    rdfs:comment "An optional URL string to display to contributors who are blocked from pushing a secret." ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "secret_scanning_push_protection_custom_link" .

ns1:secretScanningPushProtectionEnabledForNewRepositories a owl:DatatypeProperty ;
    rdfs:label "secretScanningPushProtectionEnabledForNewRepositories" ;
    rdfs:comment """**Endpoint closing down notice.** Please use [code security configurations](https://docs.github.com/rest/code-security/configurations) instead.

Whether secret scanning push protection is automatically enabled for new repositories and repositories transferred to this organization.

This field is only visible to organization owners or members of a team with the security manager role.""" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "secret_scanning_push_protection_enabled_for_new_repositories" .

ns1:secretType a owl:DatatypeProperty ;
    rdfs:label "secretType" ;
    rdfs:comment "The type of secret that secret scanning detected." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "secret_type" .

ns1:secretTypeDisplayName a owl:DatatypeProperty ;
    rdfs:label "secretTypeDisplayName" ;
    rdfs:comment """User-friendly name for the detected secret, matching the `secret_type`.
For a list of built-in patterns, see "[Supported secret scanning patterns](https://docs.github.com/code-security/secret-scanning/introduction/supported-secret-scanning-patterns#supported-secrets).\"""" ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "secret_type_display_name" .

ns1:severity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:comment "The severity of the advisory." ;
    rdfs:domain ns1:GlobalAdvisory,
        ns1:RepositoryAdvisory ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "severity" ;
    ns1:required true .

ns1:side a owl:DatatypeProperty ;
    rdfs:label "side" ;
    rdfs:comment "The side of the diff to which the comment applies. The side of the last line of the range for a multi-line comment" ;
    rdfs:domain ns1:PullRequestReviewComment ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "side" .

ns1:siteAdmin a owl:DatatypeProperty ;
    rdfs:label "siteAdmin" ;
    rdfs:domain ns1:User ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "site_admin" ;
    ns1:required true .

ns1:size a owl:DatatypeProperty ;
    rdfs:label "size" ;
    rdfs:comment "The size of the repository, in kilobytes. Size is calculated hourly. When a repository is initially created, the size is 0." ;
    rdfs:domain ns1:ReleaseAsset,
        ns1:Repository ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "size" ;
    ns1:required true .

ns1:slug a owl:DatatypeProperty ;
    rdfs:label "slug" ;
    rdfs:domain ns1:Team,
        ns1:TeamFull ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "slug" ;
    ns1:required true .

ns1:source a owl:ObjectProperty ;
    rdfs:label "source" ;
    rdfs:domain ns1:Repository ;
    rdfs:range ns1:Repository ;
    ns1:openApiPropertyName "source" .

ns1:sourceCodeLocation a owl:DatatypeProperty ;
    rdfs:label "sourceCodeLocation" ;
    rdfs:comment "The URL of the advisory's source code." ;
    rdfs:domain ns1:GlobalAdvisory ;
    rdfs:range xsd:anyURI ;
    ns1:openApiPropertyName "source_code_location" ;
    ns1:required true .

ns1:spdxId a owl:DatatypeProperty ;
    rdfs:label "spdxId" ;
    rdfs:domain ns1:License ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "spdx_id" ;
    ns1:required true .

ns1:squashMergeCommitMessage a owl:DatatypeProperty ;
    rdfs:label "squashMergeCommitMessage" ;
    rdfs:comment """The default value for a squash merge commit message:

- `PR_BODY` - default to the pull request's body.
- `COMMIT_MESSAGES` - default to the branch's commit messages.
- `BLANK` - default to a blank commit message.""" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "squash_merge_commit_message" .

ns1:squashMergeCommitTitle a owl:DatatypeProperty ;
    rdfs:label "squashMergeCommitTitle" ;
    rdfs:comment """The default value for a squash merge commit title:

- `PR_TITLE` - default to the pull request's title.
- `COMMIT_OR_PR_TITLE` - default to the commit's title (if only one commit) or the pull request's title (when more than one commit).""" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "squash_merge_commit_title" .

ns1:stargazersCount a owl:DatatypeProperty ;
    rdfs:label "stargazersCount" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "stargazers_count" ;
    ns1:required true .

ns1:starredAt a owl:DatatypeProperty ;
    rdfs:label "starredAt" ;
    rdfs:domain ns1:User ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "starred_at" .

ns1:startLine a owl:DatatypeProperty ;
    rdfs:label "startLine" ;
    rdfs:comment "The first line of the range for a multi-line comment." ;
    rdfs:domain ns1:PullRequestReviewComment ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "start_line" .

ns1:startSide a owl:DatatypeProperty ;
    rdfs:label "startSide" ;
    rdfs:comment "The side of the first line of the range for a multi-line comment." ;
    rdfs:domain ns1:PullRequestReviewComment ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "start_side" .

ns1:state a owl:DatatypeProperty ;
    rdfs:label "state" ;
    rdfs:comment "State of the issue; either 'open' or 'closed'",
        "State of the release asset.",
        "State of this Pull Request. Either `open` or `closed`.",
        """The current state of the discussion.
`converting` means that the discussion is being converted from an issue.
`transferring` means that the discussion is being transferred from another repository.""",
        "The state of the Dependabot alert.",
        "The state of the advisory.",
        "The state of the member in the organization. The `pending` state indicates the user has not yet accepted an invitation.",
        "The state of the milestone." ;
    rdfs:domain ns1:DependabotAlert,
        ns1:DependabotAlertWithRepository,
        ns1:Discussion,
        ns1:Issue,
        ns1:Milestone,
        ns1:OrgMembership,
        ns1:PullRequest,
        ns1:PullRequestReview,
        ns1:ReleaseAsset,
        ns1:RepositoryAdvisory ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "state" ;
    ns1:required true .

ns1:stateReason a owl:DatatypeProperty ;
    rdfs:label "stateReason" ;
    rdfs:comment "The reason for the current state" ;
    rdfs:domain ns1:Discussion,
        ns1:Issue ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "state_reason" ;
    ns1:required true .

ns1:subjectType a owl:DatatypeProperty ;
    rdfs:label "subjectType" ;
    rdfs:comment "The level at which the comment is targeted, can be a diff line or a file." ;
    rdfs:domain ns1:PullRequestReviewComment ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "subject_type" .

ns1:submittedAt a owl:DatatypeProperty ;
    rdfs:label "submittedAt" ;
    rdfs:domain ns1:PullRequestReview ;
    rdfs:range xsd:dateTime ;
    ns1:openApiPropertyName "submitted_at" .

ns1:subscribersCount a owl:DatatypeProperty ;
    rdfs:label "subscribersCount" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "subscribers_count" ;
    ns1:required true .

ns1:subscribersUrl a owl:DatatypeProperty ;
    rdfs:label "subscribersUrl" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:anyURI ;
    ns1:openApiPropertyName "subscribers_url" ;
    ns1:required true .

ns1:subscriptionUrl a owl:DatatypeProperty ;
    rdfs:label "subscriptionUrl" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:anyURI ;
    ns1:openApiPropertyName "subscription_url" ;
    ns1:required true .

ns1:summary a owl:DatatypeProperty ;
    rdfs:label "summary" ;
    rdfs:comment "A short summary of the advisory." ;
    rdfs:domain ns1:GlobalAdvisory,
        ns1:RepositoryAdvisory ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "summary" ;
    ns1:required true .

ns1:tagName a owl:DatatypeProperty ;
    rdfs:label "tagName" ;
    rdfs:comment "The name of the tag." ;
    rdfs:domain ns1:Release ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "tag_name" ;
    ns1:required true .

ns1:targetCommitish a owl:DatatypeProperty ;
    rdfs:label "targetCommitish" ;
    rdfs:comment "Specifies the commitish value that determines where the Git tag is created from." ;
    rdfs:domain ns1:Release ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "target_commitish" ;
    ns1:required true .

ns1:tempCloneToken a owl:DatatypeProperty ;
    rdfs:label "tempCloneToken" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "temp_clone_token" .

ns1:templateRepository a owl:ObjectProperty ;
    rdfs:label "templateRepository" ;
    rdfs:domain ns1:Repository ;
    rdfs:range ns1:Repository ;
    ns1:openApiPropertyName "template_repository" .

ns1:timelineUrl a owl:DatatypeProperty ;
    rdfs:label "timelineUrl" ;
    rdfs:domain ns1:Discussion,
        ns1:Issue ;
    rdfs:range xsd:anyURI,
        xsd:string ;
    ns1:openApiPropertyName "timeline_url" .

ns1:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:comment "The title of the milestone.",
        "The title of the pull request.",
        "Title of the issue" ;
    rdfs:domain ns1:Discussion,
        ns1:Issue,
        ns1:Milestone,
        ns1:PullRequest ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "title" ;
    ns1:required true .

ns1:topics a owl:DatatypeProperty ;
    rdfs:label "topics" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "topics" .

ns1:totalCount a owl:DatatypeProperty ;
    rdfs:label "totalCount" ;
    rdfs:domain ns1:ReactionRollup ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "total_count" ;
    ns1:required true .

ns1:totalPrivateRepos a owl:DatatypeProperty ;
    rdfs:label "totalPrivateRepos" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "total_private_repos" .

ns1:twitterUsername a owl:DatatypeProperty ;
    rdfs:label "twitterUsername" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "twitter_username" .

ns1:twoFactorRequirementEnabled a owl:DatatypeProperty ;
    rdfs:label "twoFactorRequirementEnabled" ;
    rdfs:domain ns1:Organization ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "two_factor_requirement_enabled" .

ns1:type a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:comment "The ownership type of the team",
        "The type of advisory." ;
    rdfs:domain ns1:GlobalAdvisory,
        ns1:Organization,
        ns1:Team,
        ns1:TeamFull,
        ns1:User ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "type" ;
    ns1:required true .

ns1:updatedAt a owl:DatatypeProperty ;
    rdfs:label "updatedAt" ;
    rdfs:comment "The date and time of when the advisory was last updated, in ISO 8601 format." ;
    rdfs:domain ns1:Discussion,
        ns1:GlobalAdvisory,
        ns1:Issue,
        ns1:IssueComment,
        ns1:Milestone,
        ns1:Organization,
        ns1:PullRequest,
        ns1:PullRequestReviewComment,
        ns1:Release,
        ns1:ReleaseAsset,
        ns1:Repository,
        ns1:RepositoryAdvisory,
        ns1:TeamFull ;
    rdfs:range xsd:dateTime ;
    ns1:openApiPropertyName "updated_at" ;
    ns1:required true .

ns1:uploader a owl:ObjectProperty ;
    rdfs:label "uploader" ;
    rdfs:domain ns1:ReleaseAsset ;
    rdfs:range ns1:User ;
    ns1:openApiPropertyName "uploader" .

ns1:user a owl:ObjectProperty ;
    rdfs:label "user" ;
    rdfs:domain ns1:Issue,
        ns1:IssueComment,
        ns1:OrgMembership,
        ns1:PullRequest,
        ns1:PullRequestReview,
        ns1:PullRequestReviewComment ;
    rdfs:range ns1:User ;
    ns1:openApiPropertyName "user" .

ns1:userViewType a owl:DatatypeProperty ;
    rdfs:label "userViewType" ;
    rdfs:domain ns1:User ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "user_view_type" .

ns1:validity a owl:DatatypeProperty ;
    rdfs:label "validity" ;
    rdfs:comment "The token status as of the latest validity check." ;
    rdfs:domain ns1:SecretScanningAlert ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "validity" .

ns1:visibility a owl:DatatypeProperty ;
    rdfs:label "visibility" ;
    rdfs:comment "The repository visibility: public, private, or internal." ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "visibility" .

ns1:vulnerabilities a owl:ObjectProperty ;
    rdfs:label "vulnerabilities" ;
    rdfs:comment "The products and respective version ranges affected by the advisory." ;
    rdfs:domain ns1:GlobalAdvisory ;
    rdfs:range ns1:Vulnerability ;
    ns1:openApiPropertyName "vulnerabilities" .

ns1:vulnerableFunctions a owl:DatatypeProperty ;
    rdfs:label "vulnerableFunctions" ;
    rdfs:comment "The functions in the package that are affected by the vulnerability." ;
    rdfs:domain ns1:Vulnerability ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "vulnerable_functions" .

ns1:vulnerableVersionRange a owl:DatatypeProperty ;
    rdfs:label "vulnerableVersionRange" ;
    rdfs:comment "The range of the package versions affected by the vulnerability." ;
    rdfs:domain ns1:Vulnerability ;
    rdfs:range xsd:string ;
    ns1:openApiPropertyName "vulnerable_version_range" ;
    ns1:required true .

ns1:watchers a owl:DatatypeProperty ;
    rdfs:label "watchers" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "watchers" ;
    ns1:required true .

ns1:watchersCount a owl:DatatypeProperty ;
    rdfs:label "watchersCount" ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "watchers_count" ;
    ns1:required true .

ns1:webCommitSignoffRequired a owl:DatatypeProperty ;
    rdfs:label "webCommitSignoffRequired" ;
    rdfs:domain ns1:Organization,
        ns1:Repository ;
    rdfs:range xsd:boolean ;
    ns1:openApiPropertyName "web_commit_signoff_required" .

ns1:withdrawnAt a owl:DatatypeProperty ;
    rdfs:label "withdrawnAt" ;
    rdfs:comment "The date and time of when the advisory was withdrawn, in ISO 8601 format." ;
    rdfs:domain ns1:GlobalAdvisory,
        ns1:RepositoryAdvisory ;
    rdfs:range xsd:dateTime ;
    ns1:openApiPropertyName "withdrawn_at" ;
    ns1:required true .

git: a owl:Ontology ;
    rdfs:label "Git Core Ontology" ;
    rdfs:comment "Core ontology for Git objects (commits, trees, blobs, tags). Extracted by introspection from GitPython bindings." ;
    owl:versionInfo "v3.1.46" .

git:abspath a owl:DatatypeProperty ;
    rdfs:label "abspath" ;
    rdfs:comment "Absolute path in the working directory" ;
    rdfs:domain git:IndexObject ;
    rdfs:range xsd:string .

git:actorName a owl:DatatypeProperty ;
    rdfs:label "actorName" ;
    rdfs:comment "The person's name" ;
    rdfs:domain git:Actor ;
    rdfs:range xsd:string .

git:author a owl:ObjectProperty ;
    rdfs:label "author" ;
    rdfs:comment "The person who originally wrote the code" ;
    rdfs:domain git:Commit ;
    rdfs:range git:Actor .

git:authorTimezone a owl:DatatypeProperty ;
    rdfs:label "authorTimezone" ;
    rdfs:comment "Author's timezone offset in seconds" ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:integer .

git:authoredDate a owl:DatatypeProperty ;
    rdfs:label "authoredDate" ;
    rdfs:comment "When the commit was authored (original creation time)" ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:dateTime .

git:bare a owl:DatatypeProperty ;
    rdfs:label "bare" ;
    rdfs:comment "Whether this is a bare repository" ;
    rdfs:domain git:Repository ;
    rdfs:range xsd:boolean .

git:binsha a owl:DatatypeProperty ;
    rdfs:label "binsha" ;
    rdfs:comment "The 20-byte binary SHA-1 hash identifying this object" ;
    rdfs:domain git:Object ;
    rdfs:range xsd:hexBinary .

git:blob a owl:ObjectProperty ;
    rdfs:label "blob" ;
    rdfs:comment "Blobs (files) contained directly in this tree" ;
    rdfs:domain git:Tree ;
    rdfs:range git:Blob .

git:branch a owl:ObjectProperty ;
    rdfs:label "branch" ;
    rdfs:comment "Local branches in this repository" ;
    rdfs:domain git:Repository ;
    rdfs:range git:Reference .

git:childCommit a owl:ObjectProperty ;
    rdfs:label "child commit" ;
    rdfs:comment "Inverse of git:parent. Inferred by reasoner: if commit B has parent A, then A has child B. Enables 'what commits came after this one?' queries." ;
    owl:inverseOf git:parent .

git:commit a owl:ObjectProperty ;
    rdfs:label "commit" ;
    rdfs:comment "The commit this reference points to" ;
    rdfs:domain git:Reference ;
    rdfs:range git:Commit .

git:committedDate a owl:DatatypeProperty ;
    rdfs:label "committedDate" ;
    rdfs:comment "When the commit was committed (may differ from authored if rebased)" ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:dateTime .

git:committer a owl:ObjectProperty ;
    rdfs:label "committer" ;
    rdfs:comment "The person who committed the code (may differ from author)" ;
    rdfs:domain git:Commit ;
    rdfs:range git:Actor .

git:committerTimezone a owl:DatatypeProperty ;
    rdfs:label "committerTimezone" ;
    rdfs:comment "Committer's timezone offset in seconds" ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:integer .

git:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:comment "Repository description from .git/description" ;
    rdfs:domain git:Repository ;
    rdfs:range xsd:string .

git:email a owl:DatatypeProperty ;
    rdfs:label "email" ;
    rdfs:comment "The person's email address" ;
    rdfs:domain git:Actor ;
    rdfs:range xsd:string .

git:encoding a owl:DatatypeProperty ;
    rdfs:label "encoding" ;
    rdfs:comment "Character encoding of the commit message" ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:string .

git:fetchUrl a owl:DatatypeProperty ;
    rdfs:label "fetchUrl" ;
    rdfs:comment "URL used for fetching" ;
    rdfs:domain git:Remote ;
    rdfs:range xsd:anyURI .

git:gitDir a owl:DatatypeProperty ;
    rdfs:label "gitDir" ;
    rdfs:comment "Path to the .git directory" ;
    rdfs:domain git:Repository ;
    rdfs:range xsd:string .

git:gpgsig a owl:DatatypeProperty ;
    rdfs:label "gpgsig" ;
    rdfs:comment "GPG signature if the commit is signed" ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:string .

git:head a owl:ObjectProperty ;
    rdfs:label "head" ;
    rdfs:comment "The HEAD reference" ;
    rdfs:domain git:Repository ;
    rdfs:range git:Reference .

git:hexsha a owl:DatatypeProperty ;
    rdfs:label "hexsha" ;
    rdfs:comment "The 40-character hexadecimal SHA-1 hash identifying this object" ;
    rdfs:domain git:Object ;
    rdfs:range xsd:string .

git:isDetached a owl:DatatypeProperty ;
    rdfs:label "isDetached" ;
    rdfs:comment "Whether HEAD is in detached state" ;
    rdfs:domain git:Reference ;
    rdfs:range xsd:boolean .

git:isRemote a owl:DatatypeProperty ;
    rdfs:label "isRemote" ;
    rdfs:comment "Whether this is a remote-tracking reference" ;
    rdfs:domain git:Reference ;
    rdfs:range xsd:boolean .

git:message a owl:DatatypeProperty ;
    rdfs:label "message" ;
    rdfs:comment "The commit message" ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:string .

git:mimeType a owl:DatatypeProperty ;
    rdfs:label "mimeType" ;
    rdfs:comment "MIME type of the file content" ;
    rdfs:domain git:Blob ;
    rdfs:range xsd:string .

git:mode a owl:DatatypeProperty ;
    rdfs:label "mode" ;
    rdfs:comment "Unix file mode bits (e.g., 33188 for regular file, 16384 for directory)" ;
    rdfs:domain git:IndexObject ;
    rdfs:range xsd:integer .

git:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Name of the file or directory" ;
    rdfs:domain git:IndexObject ;
    rdfs:range xsd:string .

git:path a owl:DatatypeProperty ;
    rdfs:label "path" ;
    rdfs:comment "Path relative to repository root" ;
    rdfs:domain git:IndexObject ;
    rdfs:range xsd:string .

git:pushUrl a owl:DatatypeProperty ;
    rdfs:label "pushUrl" ;
    rdfs:comment "URL used for pushing" ;
    rdfs:domain git:Remote ;
    rdfs:range xsd:anyURI .

git:refName a owl:DatatypeProperty ;
    rdfs:label "refName" ;
    rdfs:comment "Full reference name (e.g., 'refs/heads/main')" ;
    rdfs:domain git:Reference ;
    rdfs:range xsd:string .

git:remote a owl:ObjectProperty ;
    rdfs:label "remote" ;
    rdfs:comment "Remote repositories configured" ;
    rdfs:domain git:Repository ;
    rdfs:range git:Remote .

git:remoteName a owl:DatatypeProperty ;
    rdfs:label "remoteName" ;
    rdfs:comment "Name of the remote (e.g., 'origin')" ;
    rdfs:domain git:Remote ;
    rdfs:range xsd:string .

git:shortName a owl:DatatypeProperty ;
    rdfs:label "shortName" ;
    rdfs:comment "Short reference name (e.g., 'main')" ;
    rdfs:domain git:Reference ;
    rdfs:range xsd:string .

git:size a owl:DatatypeProperty ;
    rdfs:label "size" ;
    rdfs:comment "Size of the object in bytes" ;
    rdfs:domain git:Object ;
    rdfs:range xsd:nonNegativeInteger .

git:subtree a owl:ObjectProperty ;
    rdfs:label "subtree" ;
    rdfs:comment "Subtrees (subdirectories) contained in this tree" ;
    rdfs:domain git:Tree ;
    rdfs:range git:Tree .

git:summary a owl:DatatypeProperty ;
    rdfs:label "summary" ;
    rdfs:comment "First line of the commit message" ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:string .

git:tagMessage a owl:DatatypeProperty ;
    rdfs:label "tagMessage" ;
    rdfs:comment "Tag annotation message" ;
    rdfs:domain git:Tag ;
    rdfs:range xsd:string .

git:tagName a owl:DatatypeProperty ;
    rdfs:label "tagName" ;
    rdfs:comment "Name of the tag" ;
    rdfs:domain git:Tag ;
    rdfs:range xsd:string .

git:taggedDate a owl:DatatypeProperty ;
    rdfs:label "taggedDate" ;
    rdfs:comment "When the tag was created" ;
    rdfs:domain git:Tag ;
    rdfs:range xsd:dateTime .

git:taggedObject a owl:ObjectProperty ;
    rdfs:label "taggedObject" ;
    rdfs:comment "The object being tagged (usually a commit)" ;
    rdfs:domain git:Tag ;
    rdfs:range git:Object .

git:tagger a owl:ObjectProperty ;
    rdfs:label "tagger" ;
    rdfs:comment "Person who created the tag" ;
    rdfs:domain git:Tag ;
    rdfs:range git:Actor .

git:trackingBranch a owl:ObjectProperty ;
    rdfs:label "trackingBranch" ;
    rdfs:comment "The remote-tracking branch this local branch tracks" ;
    rdfs:domain git:Reference ;
    rdfs:range git:Reference .

git:tree a owl:ObjectProperty ;
    rdfs:label "tree" ;
    rdfs:comment "The tree object representing the project snapshot at this commit" ;
    rdfs:domain git:Commit ;
    rdfs:range git:Tree .

git:type a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:comment "The git object type string ('commit', 'tree', 'blob', 'tag')" ;
    rdfs:domain git:Object ;
    rdfs:range xsd:string .

git:url a owl:DatatypeProperty ;
    rdfs:label "url" ;
    rdfs:comment "URL of the remote repository" ;
    rdfs:domain git:Remote ;
    rdfs:range xsd:anyURI .

git:workingDir a owl:DatatypeProperty ;
    rdfs:label "workingDir" ;
    rdfs:comment "Path to the working directory" ;
    rdfs:domain git:Repository ;
    rdfs:range xsd:string .

lsp: a owl:Ontology ;
    rdfs:label "multilspy Core Ontology" ;
    rdfs:comment "Ontology for the types produced by multilspy - a language-agnostic LSP client. Covers all 11 supported language servers (Python, Java, Rust, TypeScript, JavaScript, Go, Ruby, C#, Kotlin, Dart, C++). Types are derived from multilspy's multilspy_types.py by introspection. Upstream spec: LSP v3.17.0 (microsoft.github.io/language-server-protocol)." ;
    rdfs:seeAlso "https://microsoft.github.io/language-server-protocol/specifications/lsp/3.17/specification/" ;
    owl:versionInfo "v0.0.15" .

lsp:CompletionItemKind-Class a lsp:CompletionItemKind ;
    rdfs:label "Class" ;
    lsp:completionItemKindValue 7 .

lsp:CompletionItemKind-Color a lsp:CompletionItemKind ;
    rdfs:label "Color" ;
    lsp:completionItemKindValue 16 .

lsp:CompletionItemKind-Constant a lsp:CompletionItemKind ;
    rdfs:label "Constant" ;
    lsp:completionItemKindValue 21 .

