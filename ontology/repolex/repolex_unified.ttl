lsp:WorkspaceSymbolRequest a owl:Class ;
    rdfs:label "WorkspaceSymbolRequest" ;
    rdfs:comment "A workspace/symbol request. Searches for symbols matching a query string across the entire repository. Corresponds to SyncLanguageServer.request_workspace_symbol()." ;
    rdfs:subClassOf lsp:LspRequest .

lsp:absolutePath a owl:DatatypeProperty ;
    rdfs:label "absolutePath" ;
    rdfs:comment "Absolute filesystem path to the file. (multilspy addition, not in LSP spec.)" ;
    rdfs:domain lsp:Location ;
    rdfs:range xsd:string .

lsp:character a owl:DatatypeProperty ;
    rdfs:label "character" ;
    rdfs:comment "Zero-based character offset on the line." ;
    rdfs:domain lsp:Position ;
    rdfs:range xsd:nonNegativeInteger .

lsp:completionDetail a owl:DatatypeProperty ;
    rdfs:label "completionDetail" ;
    rdfs:comment "A human-readable string with additional information about this item, such as type or symbol information. Optional. Note: serialised as 'detail' in the TypedDict." ;
    rdfs:domain lsp:CompletionItem ;
    rdfs:range xsd:string .

lsp:completionItemKindValue a owl:DatatypeProperty ;
    rdfs:label "completionItemKindValue" ;
    rdfs:comment "The integer value of the CompletionItemKind as defined in the LSP spec." ;
    rdfs:domain lsp:CompletionItemKind ;
    rdfs:range xsd:integer .

lsp:completionKind a owl:ObjectProperty ;
    rdfs:label "completionKind" ;
    rdfs:comment "The kind of completion item (method, function, class, variable, etc.). Note: serialised as 'kind' in the TypedDict." ;
    rdfs:domain lsp:CompletionItem ;
    rdfs:range lsp:CompletionItemKind .

lsp:completionText a owl:DatatypeProperty ;
    rdfs:label "completionText" ;
    rdfs:comment "The text to insert when this completion is selected. (multilspy field name; LSP spec uses 'label'.)" ;
    rdfs:domain lsp:CompletionItem ;
    rdfs:range xsd:string .

lsp:containerName a owl:DatatypeProperty ;
    rdfs:label "containerName" ;
    rdfs:comment "The name of the symbol containing this symbol, for display purposes. Optional." ;
    rdfs:domain lsp:UnifiedSymbolInformation ;
    rdfs:range xsd:string .

lsp:contents a owl:ObjectProperty ;
    rdfs:label "contents" ;
    rdfs:comment "The hover contents. May be MarkupContent, a MarkedString, or a list of MarkedStrings (the latter two are deprecated LSP formats)." ;
    rdfs:domain lsp:Hover ;
    rdfs:range lsp:MarkupContent .

lsp:deprecated a owl:DatatypeProperty ;
    rdfs:label "deprecated" ;
    rdfs:comment "Whether this symbol is deprecated. Optional. @deprecated in LSP: use tags instead." ;
    rdfs:domain lsp:UnifiedSymbolInformation ;
    rdfs:range xsd:boolean .

lsp:detail a owl:DatatypeProperty ;
    rdfs:label "detail" ;
    rdfs:comment "Additional detail for the symbol, e.g. the signature of a function. Optional." ;
    rdfs:domain lsp:UnifiedSymbolInformation ;
    rdfs:range xsd:string .

lsp:end a owl:ObjectProperty ;
    rdfs:label "end" ;
    rdfs:comment "The end position of the range (exclusive)." ;
    rdfs:domain lsp:Range ;
    rdfs:range lsp:Position .

lsp:hoverRange a owl:ObjectProperty ;
    rdfs:label "hoverRange" ;
    rdfs:comment "An optional range in the document that is used to visualise the hover. Note: serialised as 'range' in the TypedDict." ;
    rdfs:domain lsp:Hover ;
    rdfs:range lsp:Range .

lsp:kind a owl:ObjectProperty ;
    rdfs:label "kind" ;
    rdfs:comment "The kind of this symbol (class, method, function, variable, etc.)." ;
    rdfs:domain lsp:UnifiedSymbolInformation ;
    rdfs:range lsp:SymbolKind .

lsp:line a owl:DatatypeProperty ;
    rdfs:label "line" ;
    rdfs:comment "Zero-based line number in the document." ;
    rdfs:domain lsp:Position ;
    rdfs:range xsd:nonNegativeInteger .

lsp:location a owl:ObjectProperty ;
    rdfs:label "location" ;
    rdfs:comment "The location of this symbol. Optional (present for flat symbol info, absent for hierarchical document symbols)." ;
    rdfs:domain lsp:UnifiedSymbolInformation ;
    rdfs:range lsp:Location .

lsp:markedStringLanguage a owl:DatatypeProperty ;
    rdfs:label "markedStringLanguage" ;
    rdfs:comment "The language identifier for the code block (e.g. 'python', 'typescript'). Only present when MarkedString is in code-block form, not plain string form. Note: serialised as 'language' in the TypedDict." ;
    rdfs:domain lsp:MarkedString ;
    rdfs:range xsd:string .

lsp:markedStringValue a owl:DatatypeProperty ;
    rdfs:label "markedStringValue" ;
    rdfs:comment "The content of the MarkedString - either the full plain string, or the code snippet when in code-block form. Note: serialised as 'value' in the TypedDict." ;
    rdfs:domain lsp:MarkedString ;
    rdfs:range xsd:string .

lsp:markupKind a owl:ObjectProperty ;
    rdfs:label "markupKind" ;
    rdfs:comment "The type of markup (plaintext or markdown). Note: serialised as 'kind' in the TypedDict." ;
    rdfs:domain lsp:MarkupContent ;
    rdfs:range lsp:MarkupKind .

lsp:markupKindValue a owl:DatatypeProperty ;
    rdfs:label "markupKindValue" ;
    rdfs:comment "The string value of the MarkupKind ('plaintext' or 'markdown')." ;
    rdfs:domain lsp:MarkupKind ;
    rdfs:range xsd:string .

lsp:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "The name of the symbol." ;
    rdfs:domain lsp:UnifiedSymbolInformation ;
    rdfs:range xsd:string .

lsp:range a owl:ObjectProperty ;
    rdfs:label "range" ;
    rdfs:comment "The range within the document. (LSP spec field.)" ;
    rdfs:domain lsp:Location ;
    rdfs:range lsp:Range .

lsp:relativePath a owl:DatatypeProperty ;
    rdfs:label "relativePath" ;
    rdfs:comment "Path relative to the repository root. Null if the location is outside the repository (e.g. stdlib or third-party). (multilspy addition, not in LSP spec.)" ;
    rdfs:domain lsp:Location ;
    rdfs:range xsd:string .

lsp:requestCharacter a owl:DatatypeProperty ;
    rdfs:label "requestCharacter" ;
    rdfs:comment "Zero-based character offset of the query position." ;
    rdfs:domain lsp:LspRequest ;
    rdfs:range xsd:nonNegativeInteger .

lsp:requestFile a owl:DatatypeProperty ;
    rdfs:label "requestFile" ;
    rdfs:comment "Relative path to the file being queried (from repository root)." ;
    rdfs:domain lsp:LspRequest ;
    rdfs:range xsd:string .

lsp:requestLine a owl:DatatypeProperty ;
    rdfs:label "requestLine" ;
    rdfs:comment "Zero-based line number of the query position." ;
    rdfs:domain lsp:LspRequest ;
    rdfs:range xsd:nonNegativeInteger .

lsp:selectionRange a owl:ObjectProperty ;
    rdfs:label "selectionRange" ;
    rdfs:comment "The range that should be selected when this symbol is picked, e.g. the name span of a function definition. Present for hierarchical document symbols." ;
    rdfs:domain lsp:UnifiedSymbolInformation ;
    rdfs:range lsp:Range .

lsp:start a owl:ObjectProperty ;
    rdfs:label "start" ;
    rdfs:comment "The start position of the range (inclusive)." ;
    rdfs:domain lsp:Range ;
    rdfs:range lsp:Position .

lsp:symbolKindValue a owl:DatatypeProperty ;
    rdfs:label "symbolKindValue" ;
    rdfs:comment "The integer value of the SymbolKind as defined in the LSP spec." ;
    rdfs:domain lsp:SymbolKind ;
    rdfs:range xsd:integer .

lsp:symbolRange a owl:ObjectProperty ;
    rdfs:label "symbolRange" ;
    rdfs:comment "The range enclosing this symbol including comments. Present for hierarchical document symbols. Note: serialised as 'range' in the TypedDict." ;
    rdfs:domain lsp:UnifiedSymbolInformation ;
    rdfs:range lsp:Range .

lsp:symbolTagValue a owl:DatatypeProperty ;
    rdfs:label "symbolTagValue" ;
    rdfs:comment "The integer value of the SymbolTag as defined in the LSP spec." ;
    rdfs:domain lsp:SymbolTag ;
    rdfs:range xsd:integer .

lsp:treeChildren a owl:ObjectProperty ;
    rdfs:label "treeChildren" ;
    rdfs:comment "Child TreeRepr nodes nested under this node, representing symbols defined within the scope of the parent symbol." ;
    rdfs:domain lsp:TreeRepr ;
    rdfs:range lsp:TreeRepr .

lsp:treeNodeId a owl:DatatypeProperty ;
    rdfs:label "treeNodeId" ;
    rdfs:comment "The integer node ID key in the TreeRepr mapping. Corresponds to the index position of the symbol in the document symbols list." ;
    rdfs:domain lsp:TreeRepr ;
    rdfs:range xsd:integer .

lsp:uri a owl:DatatypeProperty ;
    rdfs:label "uri" ;
    rdfs:comment "The document URI as a file:// URI string. (LSP spec field.)" ;
    rdfs:domain lsp:Location ;
    rdfs:range xsd:anyURI .

lsp:value a owl:DatatypeProperty ;
    rdfs:label "value" ;
    rdfs:comment "The content itself." ;
    rdfs:domain lsp:MarkupContent ;
    rdfs:range xsd:string .

ast: a owl:Ontology ;
    rdfs:label "AST Core Ontology" ;
    rdfs:comment "Core ontology for tree-sitter AST nodes. Extracted by introspection from tree-sitter Python bindings." ;
    owl:versionInfo "v0.25" .

ast:childCount a owl:DatatypeProperty ;
    rdfs:label "childCount" ;
    rdfs:comment "Total number of children (named + anonymous)" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast:column a owl:DatatypeProperty ;
    rdfs:label "column" ;
    rdfs:comment "Column number in source code (0-indexed)" ;
    rdfs:domain ast:Point ;
    rdfs:range xsd:nonNegativeInteger .

ast:descendantCount a owl:DatatypeProperty ;
    rdfs:label "descendantCount" ;
    rdfs:comment "Total number of descendants in subtree" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast:endByte a owl:DatatypeProperty ;
    rdfs:label "endByte" ;
    rdfs:comment "Ending byte offset in source code (exclusive)" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast:endColumn a owl:DatatypeProperty ;
    rdfs:label "endColumn" ;
    rdfs:comment "Ending column number in source code (0-indexed). Convenience property derived from end_point tuple." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast:endPoint a owl:ObjectProperty ;
    rdfs:label "endPoint" ;
    rdfs:comment "Ending position in source code (Point object with row and column)" ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Point .

ast:endRow a owl:DatatypeProperty ;
    rdfs:label "endRow" ;
    rdfs:comment "Ending row (line) number in source code (0-indexed). Convenience property derived from end_point tuple." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast:grammarId a owl:DatatypeProperty ;
    rdfs:label "grammarId" ;
    rdfs:comment "Numeric ID of the grammar this node belongs to" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:integer .

ast:grammarName a owl:DatatypeProperty ;
    rdfs:label "grammarName" ;
    rdfs:comment "Name of the grammar/language (e.g., 'python', 'javascript')" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

ast:hasChanges a owl:DatatypeProperty ;
    rdfs:label "hasChanges" ;
    rdfs:comment "Whether this node changed between parses (incremental parsing)" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

ast:hasError a owl:DatatypeProperty ;
    rdfs:label "hasError" ;
    rdfs:comment "Whether this node or any descendant has an error" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

ast:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:comment "Unique numeric identifier for this node" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast:isError a owl:DatatypeProperty ;
    rdfs:label "isError" ;
    rdfs:comment "Whether this node represents a syntax error" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

ast:isExtra a owl:DatatypeProperty ;
    rdfs:label "isExtra" ;
    rdfs:comment "Whether this node is extra (e.g., comments, whitespace)" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

ast:isMissing a owl:DatatypeProperty ;
    rdfs:label "isMissing" ;
    rdfs:comment "Whether this node was inserted by error recovery" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

ast:isNamed a owl:DatatypeProperty ;
    rdfs:label "isNamed" ;
    rdfs:comment "Whether this is a named node (semantic) vs anonymous (punctuation)" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

ast:kindId a owl:DatatypeProperty ;
    rdfs:label "kindId" ;
    rdfs:comment "Numeric ID for this node kind in the language grammar" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:integer .

ast:namedChildCount a owl:DatatypeProperty ;
    rdfs:label "namedChildCount" ;
    rdfs:comment "Number of named children only" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast:nextNamedSibling a owl:ObjectProperty ;
    rdfs:label "nextNamedSibling" ;
    rdfs:comment "The next named sibling node" ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Node .

ast:nextParseState a owl:DatatypeProperty ;
    rdfs:label "nextParseState" ;
    rdfs:comment "The parse state after this node" ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast:nextSibling a owl:ObjectProperty ;
    rdfs:label "nextSibling" ;
    rdfs:comment "The next sibling node" ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Node .

ast:parent a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "parent" ;
    rdfs:comment "The parent node in the AST" ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Node .

ast:parseState a owl:DatatypeProperty ;
    rdfs:label "parseState" ;
    rdfs:comment "The parse state at the start of this node" ;
