ns1: a owl:Ontology ;
    rdfs:label "GitHub REST API Ontology" ;
    rdfs:comment "Ontology for GitHub REST API entities (issues, pull requests, reviews, etc.). Auto-extracted from GitHub's official OpenAPI spec (api version 2026-03-10)." ;
    owl:versionInfo "v2026-03-10" .

<https://repolex.ai/ontology/extracts/github/rest-api/v2026-03-10/+1> a owl:DatatypeProperty ;
    rdfs:label "+1" ;
    rdfs:domain ns1:ReactionRollup ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "+1" ;
    ns1:required true .

<https://repolex.ai/ontology/extracts/github/rest-api/v2026-03-10/-1> a owl:DatatypeProperty ;
    rdfs:label "-1" ;
    rdfs:domain ns1:ReactionRollup ;
    rdfs:range xsd:integer ;
    ns1:openApiPropertyName "-1" ;
    ns1:required true .

ns1:AuthorAssociation_COLLABORATOR a ns1:AuthorAssociation ;
    rdfs:label "COLLABORATOR" .

ns1:AuthorAssociation_CONTRIBUTOR a ns1:AuthorAssociation ;
    rdfs:label "CONTRIBUTOR" .

ns1:AuthorAssociation_FIRST_TIMER a ns1:AuthorAssociation ;
    rdfs:label "FIRST_TIMER" .

ns1:AuthorAssociation_FIRST_TIME_CONTRIBUTOR a ns1:AuthorAssociation ;
    rdfs:label "FIRST_TIME_CONTRIBUTOR" .

ns1:AuthorAssociation_MANNEQUIN a ns1:AuthorAssociation ;
    rdfs:label "MANNEQUIN" .

ns1:AuthorAssociation_MEMBER a ns1:AuthorAssociation ;
    rdfs:label "MEMBER" .

ns1:AuthorAssociation_NONE a ns1:AuthorAssociation ;
    rdfs:label "NONE" .

