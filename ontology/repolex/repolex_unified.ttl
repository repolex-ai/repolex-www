    rdfs:label "Interface" ;
    rdfs:subClassOf sem:Declaration,
        sem:Type ;
    lsp:symbolKindValue 11 .

lsp:SymbolKind-Key a lsp:SymbolKind ;
    rdfs:label "Key" ;
