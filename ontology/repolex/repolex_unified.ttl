zig:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

zig:container_doc_comment a owl:Class ;
    rdfs:label "container_doc_comment" ;
    rdfs:isDefinedBy zig: ;
    rdfs:subClassOf ast:Node ;
    zig:isSupertype true ;
    zig:nodeTypeId 119 .

zig:doc_comment a owl:Class ;
    rdfs:label "doc_comment" ;
    rdfs:isDefinedBy zig: ;
    rdfs:subClassOf ast:Node ;
    zig:isSupertype true ;
    zig:nodeTypeId 120 .

zig:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

zig:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

zig:field_exception a owl:ObjectProperty ;
    rdfs:label "exception (structural)" ;
    rdfs:comment "Structural reference for exception field when it contains a non-terminal node" ;
    zig:fieldId 1 .

zig:field_field_access a owl:ObjectProperty ;
    rdfs:label "field_access (structural)" ;
    rdfs:comment "Structural reference for field_access field when it contains a non-terminal node" ;
    zig:fieldId 2 .

zig:field_field_constant a owl:ObjectProperty ;
    rdfs:label "field_constant (structural)" ;
    rdfs:comment "Structural reference for field_constant field when it contains a non-terminal node" ;
    zig:fieldId 3 .

zig:field_field_member a owl:ObjectProperty ;
    rdfs:label "field_member (structural)" ;
    rdfs:comment "Structural reference for field_member field when it contains a non-terminal node" ;
    zig:fieldId 4 .

zig:field_function a owl:ObjectProperty ;
    rdfs:label "function (structural)" ;
    rdfs:comment "Structural reference for function field when it contains a non-terminal node" ;
    zig:fieldId 5 .

zig:field_function_call a owl:ObjectProperty ;
    rdfs:label "function_call (structural)" ;
    rdfs:comment "Structural reference for function_call field when it contains a non-terminal node" ;
    zig:fieldId 6 .

zig:field_left a owl:ObjectProperty ;
    rdfs:label "left (structural)" ;
    rdfs:comment "Structural reference for left field when it contains a non-terminal node" ;
    zig:fieldId 7 .

zig:field_operator a owl:ObjectProperty ;
    rdfs:label "operator (structural)" ;
    rdfs:comment "Structural reference for operator field when it contains a non-terminal node" ;
    zig:fieldId 8 .

zig:field_parameter a owl:ObjectProperty ;
    rdfs:label "parameter (structural)" ;
    rdfs:comment "Structural reference for parameter field when it contains a non-terminal node" ;
    zig:fieldId 9 .

zig:field_right a owl:ObjectProperty ;
    rdfs:label "right (structural)" ;
    rdfs:comment "Structural reference for right field when it contains a non-terminal node" ;
    zig:fieldId 10 .

zig:field_variable a owl:ObjectProperty ;
    rdfs:label "variable (structural)" ;
    rdfs:comment "Structural reference for variable field when it contains a non-terminal node" ;
    zig:fieldId 11 .

zig:field_variable_type_function a owl:ObjectProperty ;
    rdfs:label "variable_type_function (structural)" ;
    rdfs:comment "Structural reference for variable_type_function field when it contains a non-terminal node" ;
    zig:fieldId 12 .

zig:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

zig:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

zig:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

zig:line_comment a owl:Class ;
    rdfs:label "line_comment" ;
    rdfs:isDefinedBy zig: ;
    rdfs:subClassOf ast:Node ;
    zig:isSupertype true ;
    zig:nodeTypeId 121 .

zig:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

zig:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

zig:operator a owl:DatatypeProperty ;
    rdfs:label "operator (literal)" ;
    rdfs:comment "Literal value for operator field when it contains a terminal node" ;
    zig:fieldId 8 ;
    zig:isTerminalField true .

zig:source_file a owl:Class ;
    rdfs:label "source_file" ;
    rdfs:isDefinedBy zig: ;
    rdfs:subClassOf ast:Node ;
    zig:isSupertype true ;
    zig:nodeTypeId 151 .

repolex: a owl:Ontology ;
    rdfs:label "Repolex Core Ontology" ;
    rdfs:comment "Core Repolex application ontology defining repository analysis vocabulary." ;
    owl:versionInfo "1.0" .

repolex:ast-extension a owl:Ontology ;
    rdfs:label "AST Extension Ontology" ;
    rdfs:comment "Universal AST types and extensions for cross-language analysis. Maps language-specific tree-sitter nodes to generic ast-x: classes via rdfs:subClassOf." ;
    owl:versionInfo "1.0" .

ast-x:assignmentCount a owl:DatatypeProperty ;
    rdfs:label "assignment count" ;
    rdfs:comment "Count of assignment operations in the function. High values indicate mutation-heavy code. NOT YET IMPLEMENTED. To implement: Count nodes that are subclasses of ast-x:Assignment or ast-x:AugmentedAssignment within function body." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:assignsTo a owl:DatatypeProperty ;
    rdfs:label "assigns to" ;
    rdfs:comment "Target variable name for assignment operations. Extracted from the left-hand side (field_left) of assignment nodes during blob parsing. For simple assignments only; complex targets (destructuring, field access) require following the assignment structure." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

ast-x:branchCount a owl:DatatypeProperty ;
    rdfs:label "branch count" ;
    rdfs:comment "Count of if/switch statements in the function. NOT YET IMPLEMENTED. To implement: Count nodes that are subclasses of ast-x:IfStatement or ast-x:SwitchStatement within function body." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:containedInBlob a owl:ObjectProperty ;
    rdfs:label "contained in blob" ;
    rdfs:comment "Inverse of ast-x:sourceBlobNode. Inferred by reasoner: if node N is in blob B, then B contains N. Enables 'what nodes are in this blob?' queries." ;
    owl:inverseOf ast-x:sourceBlobNode .

ast-x:cyclomaticComplexity a owl:DatatypeProperty ;
    rdfs:label "cyclomatic complexity" ;
    rdfs:comment "McCabe cyclomatic complexity: count of decision points + 1. Higher values indicate more complex control flow. NOT YET IMPLEMENTED. To implement: During AST traversal, count decision point nodes (if_statement, for_statement, while_statement, switch_statement, conditional_expression, boolean operators &&/||) + 1. Language-specific node types map via ast-x:IfStatement, ast-x:ForStatement, etc." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:docstring a owl:DatatypeProperty ;
    rdfs:label "docstring" ;
    rdfs:comment "Documentation text attached to a function, class, or module. Extracted from the first ast-x:Comment child of an ast-x:FunctionDefinition or ast-x:ClassDefinition during parse time. Used for documentation coverage analysis and LLM context." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

ast-x:exceptionHandlerCount a owl:DatatypeProperty ;
    rdfs:label "exception handler count" ;
    rdfs:comment "Count of try/catch blocks in the function. NOT YET IMPLEMENTED. To implement: Count nodes that are subclasses of ast-x:TryStatement within function body." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:fieldCount a owl:DatatypeProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Number of fields/properties in a class. NOT YET IMPLEMENTED. To implement: Count field/property declaration nodes within class body. Language-specific patterns needed (field_declaration, property_declaration, etc.)." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:filePath a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "file path" ;
    rdfs:comment "Repository-relative file path for this AST node (e.g., 'src/main.js', 'lib/utils/helper.py'). Used to locate the source file within the repository structure." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

ast-x:hasDocumentation a owl:DatatypeProperty ;
    rdfs:label "has documentation" ;
    rdfs:comment "Whether this symbol has documentation comments (JSDoc, docstring, JavaDoc, etc.). Used for documentation coverage analysis. NOT YET IMPLEMENTED. To implement: During AST traversal, check for doc comment nodes immediately preceding or inside the definition. Language-specific patterns: jsdoc comment nodes (JS/TS), expression_statement with string literal at function start (Python), block_comment starting with /** (Java/C++), triple-slash comments (C#), etc." ;
    rdfs:range xsd:boolean .

ast-x:importResolvesTo a owl:ObjectProperty ;
    rdfs:label "import resolves to" ;
    rdfs:comment "Inferred: follows from import statement through its resolution node to the LSP-resolved target location. Chain: importStatement --resolutionNode--> node --importTarget--> location." ;
    owl:propertyChainAxiom ( ast-x:resolutionNode lsp-x:importTarget ) .

ast-x:isOptional a owl:DatatypeProperty ;
    rdfs:label "is optional" ;
    rdfs:comment "Whether this parameter is optional/has a default value. Detected via .scm queries looking for: TypeScript '?' suffix, Python/Kotlin default values, etc. Populated during blob parsing." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

ast-x:lineCount a owl:DatatypeProperty ;
    rdfs:label "line count" ;
    rdfs:comment "Number of lines spanned by this entity (endLine - startLine + 1). NOT YET IMPLEMENTED. To implement: Use ast:endRow - ast:startRow + 1 from tree-sitter node." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:localVariableCount a owl:DatatypeProperty ;
    rdfs:label "local variable count" ;
    rdfs:comment "Number of local variable declarations in the function. NOT YET IMPLEMENTED. To implement: Count nodes that are subclasses of ast-x:VariableDeclaration within function body (excluding parameters and class fields)." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:loopCount a owl:DatatypeProperty ;
    rdfs:label "loop count" ;
    rdfs:comment "Count of for/while loops in the function. NOT YET IMPLEMENTED. To implement: Count nodes that are subclasses of ast-x:ForStatement or ast-x:WhileStatement within function body." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:methodCount a owl:DatatypeProperty ;
    rdfs:label "method count" ;
    rdfs:comment "Number of methods in a class. NOT YET IMPLEMENTED. To implement: Count child nodes that are subclasses of ast-x:FunctionDefinition within class body." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:nestingDepth a owl:DatatypeProperty ;
    rdfs:label "nesting depth" ;
    rdfs:comment "Maximum depth of nested control flow structures. Deep nesting indicates harder-to-understand code. NOT YET IMPLEMENTED. To implement: During AST traversal, track current depth counter. Increment when entering control flow nodes (subclasses of sem:ControlFlow), decrement when exiting. Record max depth reached." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:parameterCount a owl:DatatypeProperty ;
    rdfs:label "parameter count" ;
    rdfs:comment "Number of parameters for a function/method. NOT YET IMPLEMENTED. To implement: Count child nodes that are subclasses of ast-x:Parameter within function definition." ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:parameterIndex a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "parameter index" ;
    rdfs:comment "Zero-indexed position of this parameter in the function signature. Computed during AST traversal by counting parameter positions. Used for argument-to-parameter dataflow mapping." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

ast-x:returnCount a owl:DatatypeProperty ;
    rdfs:label "return count" ;
    rdfs:comment "Number of return statements in the function. Multiple returns can indicate complex control flow. NOT YET IMPLEMENTED. To implement: Count nodes that are subclasses of ast-x:ReturnStatement within function body." ;
    rdfs:range xsd:nonNegativeInteger .

repolex:blobHash a owl:DatatypeProperty ;
    rdfs:label "blob hash" ;
    rdfs:comment "Git blob hash (SHA-1) of the file contents" ;
    rdfs:domain repolex:File ;
    rdfs:range xsd:string .

repolex:blobUri a owl:DatatypeProperty ;
    rdfs:label "blob URI" ;
    rdfs:comment "URI reference to the blob resource" ;
    rdfs:domain repolex:File ;
    rdfs:range xsd:anyURI .

repolex:dependencyRepo a owl:ObjectProperty ;
    rdfs:label "dependency repo" ;
    rdfs:comment "A repository that this commit depends on. Resolved from package manifest (requirements.txt, pom.xml, etc.) via package registry to GitHub repo. Used in manifest graphs to build the cross-repo dependency web." ;
    rdfs:domain git:Commit ;
    rdfs:range ns1:Repository .

repolex:fileName a owl:DatatypeProperty ;
    rdfs:label "file name" ;
    rdfs:comment "Base name of the file (e.g., 'main.py')" ;
    rdfs:domain repolex:File ;
    rdfs:range xsd:string .

repolex:filePath a owl:DatatypeProperty ;
    rdfs:label "file path" ;
    rdfs:comment "Relative path of the file within the repository" ;
    rdfs:domain repolex:File ;
    rdfs:range xsd:string .

repolex:fileSize a owl:DatatypeProperty ;
    rdfs:label "file size" ;
    rdfs:comment "Size of the file in bytes" ;
    rdfs:domain repolex:File ;
    rdfs:range xsd:integer .

repolex:gh-extension a owl:Ontology ;
    rdfs:label "GitHub Extension Ontology" ;
    rdfs:comment "Repolex extension types and properties for GitHub data. Defines gh-x:Item superclass and convenience properties not found in the upstream GitHub OpenAPI spec." ;
    owl:versionInfo "1.0" .

<https://repolex.ai/ontology/repolex/gh-extension/baseRef> a owl:DatatypeProperty ;
    rdfs:label "baseRef" ;
    rdfs:comment "Branch name of the PR's base (target) branch. Extracted from the GitHub API base.ref field." ;
    rdfs:domain ns1:PullRequest ;
    rdfs:range xsd:string .

<https://repolex.ai/ontology/repolex/gh-extension/headRef> a owl:DatatypeProperty ;
    rdfs:label "headRef" ;
    rdfs:comment "Branch name of the PR's head (source) branch. Extracted from the GitHub API head.ref field." ;
    rdfs:domain ns1:PullRequest ;
    rdfs:range xsd:string .

<https://repolex.ai/ontology/repolex/gh-extension/headSha> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "headSha" ;
    rdfs:comment "Points to the git:Commit at the tip of the PR's head branch. Extracted from the GitHub API head.sha field and linked to the corresponding commit URI." ;
    rdfs:domain ns1:PullRequest ;
    rdfs:range git:Commit .

<https://repolex.ai/ontology/repolex/gh-extension/mergeCommitSha> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "mergeCommitSha" ;
    rdfs:comment "Points to the git:Commit created when this PR was merged. Extracted from the GitHub API merge_commit_sha field and linked to the corresponding commit URI." ;
    rdfs:domain ns1:PullRequest ;
    rdfs:range git:Commit .

<https://repolex.ai/ontology/repolex/gh-extension/totalReactions> a owl:DatatypeProperty ;
    rdfs:label "totalReactions" ;
    rdfs:comment "Sum of all reaction counts on this item. Computed from the GitHub API reactions.total_count field as a convenience rollup." ;
    rdfs:domain <https://repolex.ai/ontology/repolex/gh-extension/Item> ;
    rdfs:range xsd:integer .

repolex:githubCommit a owl:DatatypeProperty ;
    rdfs:label "GitHub commit" ;
    rdfs:comment "Git commit SHA-1 hash for the resolved version" ;
    rdfs:domain repolex:Dependency ;
    rdfs:range xsd:string .

repolex:githubLink a owl:DatatypeProperty ;
    rdfs:label "GitHub link" ;
    rdfs:comment "Full GitHub URL to the repository" ;
    rdfs:domain repolex:Dependency ;
    rdfs:range xsd:anyURI .

repolex:githubOrg a owl:DatatypeProperty ;
    rdfs:label "GitHub organization" ;
    rdfs:comment "GitHub organization or user name hosting the dependency" ;
    rdfs:domain repolex:Dependency ;
    rdfs:range xsd:string .

repolex:githubRepo a owl:DatatypeProperty ;
    rdfs:label "GitHub repository" ;
    rdfs:comment "GitHub repository name" ;
    rdfs:domain repolex:Dependency ;
    rdfs:range xsd:string .

repolex:githubTag a owl:DatatypeProperty ;
    rdfs:label "GitHub tag" ;
    rdfs:comment "Git tag corresponding to the resolved package version" ;
    rdfs:domain repolex:Dependency ;
    rdfs:range xsd:string .

repolex:githubUri a owl:DatatypeProperty ;
    rdfs:label "GitHub URI" ;
    rdfs:comment "GitHub web URL for viewing this file" ;
    rdfs:domain repolex:File ;
    rdfs:range xsd:anyURI .

repolex:graphFile a owl:ObjectProperty ;
    rdfs:label "graph file" ;
    rdfs:comment "Links a commit to one of its output graph files (AST, LSP, repolex, dep, filetree, commit, branch, tag)." ;
    rdfs:domain git:Commit ;
    rdfs:range repolex:GraphFile .

repolex:graphFilePath a owl:DatatypeProperty ;
    rdfs:label "graph file path" ;
    rdfs:comment "Relative path to the .nq.gz file within the storage repo." ;
    rdfs:domain repolex:GraphFile ;
    rdfs:range xsd:string .

repolex:graphFileSize a owl:DatatypeProperty ;
    rdfs:label "graph file size" ;
    rdfs:comment "Size of the .nq.gz file in bytes." ;
    rdfs:domain repolex:GraphFile ;
    rdfs:range xsd:integer .

repolex:graphType a owl:DatatypeProperty ;
    rdfs:label "graph type" ;
    rdfs:comment "Type of graph: 'ast', 'lsp', 'repolex', 'dep', 'filetree', 'commit', 'branch', 'tag', 'issue', 'pr'." ;
    rdfs:domain repolex:GraphFile ;
    rdfs:range xsd:string .

repolex:language a owl:DatatypeProperty ;
    rdfs:label "language" ;
    rdfs:comment "Programming language (e.g., 'python', 'javascript', 'rust')" ;
    rdfs:range xsd:string .

repolex:lsp-extension a owl:Ontology ;
    rdfs:label "LSP Extension Ontology" ;
    rdfs:comment "Properties and metrics derived from LSP data via multilspy resolution and call graph analysis." ;
    owl:versionInfo "1.0" .

lsp-x:callFromReturn a owl:ObjectProperty ;
    rdfs:label "call from return" ;
    rdfs:comment "Inverse of lsp-x:returnToCall. Inferred by reasoner: if return R flows to call site C, then C receives from R. Enables 'what return values reach this call?' queries." ;
    owl:inverseOf lsp-x:returnToCall .

lsp-x:callSource a owl:ObjectProperty ;
    rdfs:label "call source" ;
    rdfs:comment "Inverse of lsp-x:callTarget. Inferred by reasoner: if A lsp-x:callTarget B, then B lsp-x:callSource A. Enables 'who calls this function?' queries without storing both directions." ;
    owl:inverseOf lsp-x:callTarget .

lsp-x:callTargetFile a owl:DatatypeProperty ;
    rdfs:label "call target file (DEPRECATED)" ;
    rdfs:comment "DEPRECATED — use lsp-x:resolutionTargetFile instead. Repository-relative file path of the call target." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

lsp-x:callTargetLine a owl:DatatypeProperty ;
    rdfs:label "call target line" ;
    rdfs:comment "Line number where the call target is defined, extracted from LSP Location response. Convenience property for quick access without following lsp-x:callTarget." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

lsp-x:callTargetName a owl:DatatypeProperty ;
    rdfs:label "call target name" ;
    rdfs:comment "Symbol name of the call target, extracted from LSP Hover response (best-effort). Convenience property for displaying target name without additional lookups." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

lsp-x:calledByCount a owl:DatatypeProperty ;
    rdfs:label "called by count" ;
    rdfs:comment "Fan-in: Number of distinct callers that call this function. Computed by counting how many call sites have lsp-x:callTarget pointing to this function." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

lsp-x:callsCount a owl:DatatypeProperty ;
    rdfs:label "calls count" ;
    rdfs:comment "Fan-out: Number of distinct functions this function calls. Computed by counting distinct lsp-x:callTarget triples where the subject is a call site within this function." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

lsp-x:childClassCount a owl:DatatypeProperty ;
    rdfs:label "child class count" ;
    rdfs:comment "Number of direct subclasses. Changes to classes with many children have wide ripple effects. Computed from LSP TypeHierarchyRequest (subtypes count)." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

lsp-x:importModule a owl:DatatypeProperty ;
    rdfs:label "import module" ;
    rdfs:comment "The module name or path being imported (e.g., 'react', 'lodash', './utils/helper'). Extracted from the import statement source text. Convenience property for quick access to import target without LSP resolution." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

lsp-x:importSource a owl:ObjectProperty ;
    rdfs:label "import source" ;
    rdfs:comment "Inverse of lsp-x:importTarget. Inferred by reasoner: if module A imports module B, then B lsp-x:importSource A. Enables 'who imports this module?' queries." ;
    owl:inverseOf lsp-x:importTarget .

lsp-x:importSymbol a owl:DatatypeProperty ;
    rdfs:label "import symbol" ;
    rdfs:comment "Specific symbol name imported from the module (e.g., 'useState' from 'react', 'Path' from 'pathlib'). Optional — not present for wildcard or module-level imports." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

lsp-x:inheritanceDepth a owl:DatatypeProperty ;
    rdfs:label "inheritance depth" ;
    rdfs:comment "Distance from root class in the inheritance hierarchy. Deep hierarchies can be harder to understand. Computed from LSP TypeHierarchyRequest (supertypes traversal)." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

lsp-x:paramFromArg a owl:ObjectProperty ;
    rdfs:label "parameter from argument" ;
    rdfs:comment "Inverse of lsp-x:argToParam. Inferred by reasoner: if argument A flows to parameter P, then P receives from A. Enables 'what arguments feed this parameter?' queries." ;
    owl:inverseOf lsp-x:argToParam .

lsp-x:resolutionSourceFile a owl:DatatypeProperty ;
    rdfs:label "resolution source file" ;
    rdfs:comment "Repo-relative file path where the LSP resolution originated (the caller/importer side). Denormalized on all LSP resolution triples (calls, imports, extends) for file-level filtering and incremental enrichment." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

lsp-x:resolutionTargetFile a owl:DatatypeProperty ;
    rdfs:label "resolution target file" ;
    rdfs:comment "Repo-relative file path where LSP resolved to (the definition/target side). Denormalized on all LSP resolution triples for file-level filtering and version diffs. Replaces the narrower lsp-x:callTargetFile." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:string .

lsp-x:transitivelyImports a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "transitively imports" ;
    rdfs:comment "Transitive closure of import relationships. If module A imports B and B imports C, the reasoner infers A transitivelyImports C. Enables full dependency tree queries without recursion." ;
    rdfs:subPropertyOf lsp-x:importTarget .

repolex:mimeType a owl:DatatypeProperty ;
    rdfs:label "MIME type" ;
    rdfs:comment "MIME type of the file (e.g., 'text/x-python')" ;
    rdfs:domain repolex:File ;
    rdfs:range xsd:string .

repolex:packageEcosystem a owl:DatatypeProperty ;
    rdfs:label "package ecosystem" ;
    rdfs:comment "The package ecosystem/registry (e.g., 'PYPI', 'NPM', 'MAVEN')" ;
    rdfs:domain repolex:Dependency ;
    rdfs:range xsd:string .

repolex:packageName a owl:DatatypeProperty ;
    rdfs:label "package name" ;
    rdfs:comment "The package name as it appears in the registry (e.g., 'requests', 'express')" ;
    rdfs:domain repolex:Dependency ;
    rdfs:range xsd:string .

repolex:packageVersion a owl:DatatypeProperty ;
    rdfs:label "package version" ;
    rdfs:comment "The package version as declared in the dependency specification (e.g., '2.28.0', '^1.0.0')" ;
    rdfs:domain repolex:Dependency ;
    rdfs:range xsd:string .

repolex:parseStatus a owl:DatatypeProperty ;
    rdfs:label "parse status" ;
    rdfs:comment "Status of the parse for this commit: 'parsed', 'failed', or 'pending'." ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:string .

repolex:parsedAt a owl:DatatypeProperty ;
    rdfs:label "parsed at" ;
    rdfs:comment "Datetime when this commit was parsed by repolex." ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:dateTime .

repolex:parserVersion a owl:DatatypeProperty ;
    rdfs:label "parser version" ;
    rdfs:comment "Version of the repolex parser that produced this parse. Used for tracking which parser version generated which data." ;
    rdfs:domain git:Commit ;
    rdfs:range xsd:string .

repolex:reasoning a owl:Ontology ;
    rdfs:label "Reasoning Ontology" ;
    rdfs:comment "OWL 2 RL inference rules for the repolex knowledge graph. Defines inverse, transitive, and chain properties that enable automatic inference of implicit relationships. Requires a reasoner (owlrl) to materialize." ;
    owl:versionInfo "1.0" .

repolex:repolex_unified.ttl a owl:Ontology ;
    rdfs:label "Repolex Unified Ontology" ;
    rdfs:comment "Merged ontology generated from repolex_link.ttl. Contains tree-sitter core + 173 language ontologies, GitPython, multilspy, and the repolex cross-language mapping." ;
    owl:versionInfo "1.0" .

repolex:repository a owl:ObjectProperty ;
    rdfs:label "repository" ;
    rdfs:comment "Back-link from a commit to its repository. Convenience property for navigating from commit manifest to repo manifest." ;
    rdfs:domain git:Commit ;
    rdfs:range ns1:Repository .

repolex:root a owl:ObjectProperty ;
    rdfs:label "root" ;
    rdfs:comment "Points to the root AST node of this blob (typically module or compilation_unit)" ;
    rdfs:domain repolex:Blob .

repolex:rxm a owl:Ontology ;
    rdfs:label "RXM — Repolex Metrics" ;
    rdfs:comment "Derived code quality metrics combining AST, LSP, and graph analysis. The analysis layer that turns raw structural data into actionable insights." ;
    owl:versionInfo "1.0" .

<https://repolex.ai/ontology/repolex/rxm/changeFrequency> a owl:DatatypeProperty ;
    rdfs:label "change frequency" ;
    rdfs:comment "Number of times this entity has been modified in git history. High churn may indicate instability or complexity. NOT YET IMPLEMENTED. To implement: Query git log for commits touching this file, filter to line range of entity (ast:startRow to ast:endRow), count commits. Requires: git history integration + blame/log analysis." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

<https://repolex.ai/ontology/repolex/rxm/couplingCount> a owl:DatatypeProperty ;
    rdfs:label "coupling count" ;
    rdfs:comment "Number of distinct external classes/modules this entity depends on. High coupling indicates tight dependencies and reduced modularity. NOT YET IMPLEMENTED. To implement: For each function/class, traverse all call sites (subclasses of ast-x:CallSite), collect lsp-x:callTarget destinations, group by containing module/class (via ast:parent chain), count distinct external modules. Requires: lsp-x:callTarget resolution + module boundary detection." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

<https://repolex.ai/ontology/repolex/rxm/hasCircularDependency> a owl:DatatypeProperty ;
    rdfs:label "has circular dependency" ;
    rdfs:comment "Whether this module is part of a circular import dependency. Code smell indicator. NOT YET IMPLEMENTED. To implement: Build module dependency graph from lsp-x:importTarget resolution. Run cycle detection algorithm (Tarjan's SCC or DFS with recursion stack). Mark all modules in detected cycles. Requires: complete import resolution across all files in repository." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

<https://repolex.ai/ontology/repolex/rxm/hasHighCoupling> a owl:DatatypeProperty ;
    rdfs:label "has high coupling" ;
    rdfs:comment "Whether this class/module has excessive external dependencies (couplingCount > threshold). Code smell indicator. NOT YET IMPLEMENTED. To implement: Query for entities where rxm:couplingCount > threshold (e.g., 10). Requires: rxm:couplingCount to be populated." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

<https://repolex.ai/ontology/repolex/rxm/impactRadius> a owl:DatatypeProperty ;
    rdfs:label "impact radius" ;
    rdfs:comment "Number of entities that transitively depend on this entity. High impact radius means changes affect many other parts of the codebase. NOT YET IMPLEMENTED. To implement: Build dependency graph from lsp-x:callTarget and lsp-x:importTarget, run transitive closure from this entity, count reachable entities. Requires: complete call/import graph + graph traversal." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:nonNegativeInteger .

<https://repolex.ai/ontology/repolex/rxm/isComplexFunction> a owl:DatatypeProperty ;
    rdfs:label "is complex function" ;
    rdfs:comment "Whether this function is too complex (cyclomatic complexity > 10). Code smell indicator. NOT YET IMPLEMENTED. To implement: Query for functions where ast-x:cyclomaticComplexity > 10. Threshold configurable (common values: 10-15)." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

<https://repolex.ai/ontology/repolex/rxm/isGodClass> a owl:DatatypeProperty ;
    rdfs:label "is god class" ;
    rdfs:comment "Whether this class has too many responsibilities (methods > 20 OR fields > 15). Code smell indicator. NOT YET IMPLEMENTED. To implement: Query for classes where ast-x:methodCount > 20 OR ast-x:fieldCount > 15. Thresholds configurable." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

<https://repolex.ai/ontology/repolex/rxm/isLongFunction> a owl:DatatypeProperty ;
    rdfs:label "is long function" ;
    rdfs:comment "Whether this function is too long (line count > 100). Code smell indicator. NOT YET IMPLEMENTED. To implement: Query for functions where ast-x:lineCount > 100. Threshold configurable (common values: 50-200)." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

<https://repolex.ai/ontology/repolex/rxm/isPublicAPI> a owl:DatatypeProperty ;
    rdfs:label "is public API" ;
    rdfs:comment "Whether this symbol is part of the public API (exported/public). Used to distinguish internal code (safe to delete if unused) from external-facing code (breaking change risk). NOT YET IMPLEMENTED. To implement: Check if symbol appears in export statements (JS/TS), has public/export modifier (Java/C#/Rust), is at module level without leading underscore (Python convention), or is in __all__ (Python). Combine AST analysis with language-specific visibility rules." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

<https://repolex.ai/ontology/repolex/rxm/isReachable> a owl:DatatypeProperty ;
    rdfs:label "is reachable" ;
    rdfs:comment "Whether this code is reachable from entry points. Used for dead code elimination. NOT YET IMPLEMENTED. To implement: (1) Identify entry points (main(), if __name__ == '__main__', @Test annotations, module.exports, public APIs); (2) Build call graph from lsp-x:callTarget; (3) Run graph traversal (BFS/DFS) from entry points; (4) Mark all visited functions as reachable=true. Requires: complete lsp-x:callTarget resolution + language-specific entry point patterns." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

<https://repolex.ai/ontology/repolex/rxm/isUsed> a owl:DatatypeProperty ;
    rdfs:label "is used" ;
    rdfs:comment "Whether this variable/import/symbol is actually referenced. Used for unused code detection. NOT YET IMPLEMENTED. To implement: For imports, check if lsp-x:importTarget symbol appears in any identifier/call. For variables, check if appears in any expression beyond declaration. For functions, check lsp-x:calledByCount > 0. Can use LSP ReferencesRequest or AST-based usage tracking." ;
    rdfs:domain ast:Node ;
    rdfs:range xsd:boolean .

repolex:semantic-categories a owl:Ontology ;
    rdfs:label "Semantic Categories Ontology" ;
    rdfs:comment "Top-level semantic categories for cross-language code analysis queries. Groups AST, LSP, and computed properties into intuitive query-time buckets." ;
    owl:versionInfo "1.0" .

repolex:storageRepo a owl:DatatypeProperty ;
    rdfs:label "storage repo" ;
    rdfs:comment "GitHub storage repository where parsed data is stored (e.g., 'repolex-forx/TopQuadrant--shacl'). Written by forx." ;
    rdfs:domain ns1:Repository ;
    rdfs:range xsd:string .

repolex:trackedCommit a owl:ObjectProperty ;
    rdfs:label "tracked commit" ;
    rdfs:comment "Links a repository to a commit that is tracked for parsing (parsed, pending, or failed). Written by forx to the repo manifest." ;
    rdfs:domain ns1:Repository ;
    rdfs:range git:Commit .

repolex:usesOntology a owl:ObjectProperty ;
    rdfs:label "uses ontology" ;
    rdfs:comment "Reference to an ontology URI that this blob uses (e.g., tree-sitter core ontology, language-specific ontology)" ;
    rdfs:domain repolex:Blob ;
    rdfs:range owl:Ontology .

git:parent a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "parent" ;
    rdfs:comment "Parent commit(s). Merge commits have multiple parents." ;
    rdfs:domain git:Commit ;
    rdfs:range git:Commit .

ast-x:resolutionNode a owl:ObjectProperty ;
    rdfs:label "resolution node" ;
    rdfs:comment "Points from an import statement to the specific child node containing the module/symbol name, extracted via tree-sitter .scm query at blob parse time. The child node has the correct position for LSP resolution." ;
    rdfs:range ast:Node .

ast-x:sourceBlobNode a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "source blob node" ;
    rdfs:comment "Points to the blob node that contains this AST node's source code. Links AST nodes back to their containing blob for retrieval and reference (e.g., <blob/abc123#node_42_1_50_2>)." ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Node .

lsp-x:argToParam a owl:ObjectProperty ;
    rdfs:label "argument to parameter" ;
    rdfs:comment "Links an argument expression at a call site to the parameter definition it passes to. Populated by dataflow analysis after LSP call resolution." ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Node .

lsp-x:callTarget a owl:ObjectProperty ;
    rdfs:label "call target" ;
    rdfs:comment "The resolved definition/location of a call site, populated by multilspy LSP DefinitionRequest." ;
    rdfs:domain ast:Node ;
    rdfs:range lsp:Location .

lsp-x:returnToCall a owl:ObjectProperty ;
    rdfs:label "return to call" ;
    rdfs:comment "Links a return statement to the call site that receives its value. Populated by dataflow analysis tracking return value flow." ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Node .

sem:Import a owl:Class ;
    rdfs:label "Import" ;
    rdfs:comment "Import/include/use statements that bring external modules or symbols into scope. Used for dependency analysis." .

lsp:Hover a owl:Class ;
    rdfs:label "Hover" ;
    rdfs:comment "The result of a textDocument/hover request. Contains a human-readable string with type/documentation information for the symbol at the requested position. (LSP v3.17.0: Hover)" .

lsp:MarkedString a owl:Class ;
    rdfs:label "MarkedString" ;
    rdfs:comment "A deprecated hover content format. Either a plain string or a code block with a language identifier and value. Superseded by MarkupContent but still returned by some LSP servers. Corresponds to the Union type: str | {language: str, value: str}. (LSP v3.17.0: MarkedString, deprecated)" .

lsp:SymbolTag a owl:Class ;
    rdfs:label "SymbolTag" ;
    rdfs:comment "Extra annotations that tweak the rendering of a symbol. @since LSP v3.16.0. (LSP v3.17.0: SymbolTag)" .

repolex:Blob a owl:Class ;
    rdfs:label "Blob" ;
    rdfs:comment "A content-addressed AST blob representing the parsed syntax tree of a source file. Blobs are identified by git blob hash and contain the complete tree-sitter parse tree in RDF form." .

sem:Mutation a owl:Class ;
    rdfs:label "Mutation" ;
    rdfs:comment "State mutation constructs: assignments and augmented assignments that change variable values. Subset of DataFlow focusing on state changes." .

ns1:CodeScanningAlert a owl:Class ;
    rdfs:label "CodeScanningAlert" ;
    ns1:openApiSchemaName "code-scanning-alert" .

git:Blob a owl:Class ;
    rdfs:label "Blob" ;
    rdfs:comment "A git blob object. Represents file contents. The same content always produces the same blob hash (content-addressed storage)." ;
    rdfs:subClassOf git:IndexObject ;
    owl:disjointWith git:Tag,
        git:Tree .

lsp:CompletionItem a owl:Class ;
    rdfs:label "CompletionItem" ;
    rdfs:comment "A completion item returned by textDocument/completion. Represents a text snippet proposed to complete text being typed. (LSP v3.17.0: CompletionItem, simplified by multilspy)" .

lsp:MarkupContent a owl:Class ;
    rdfs:label "MarkupContent" ;
    rdfs:comment "A string value whose content is interpreted according to its kind (plaintext or markdown). Used in Hover responses. (LSP v3.17.0: MarkupContent)" .

lsp:TreeRepr a owl:Class ;
    rdfs:label "TreeRepr" ;
    rdfs:comment "A recursive tree structure returned alongside document symbols by request_document_symbols(). Maps integer node IDs to lists of child TreeRepr nodes, representing the hierarchical nesting of symbols in a file. Type alias: Dict[int, List[TreeRepr]]. (multilspy-specific type, not in LSP spec.)" .

ast-x:InheritanceSpecifier a owl:Class ;
    rdfs:label "inheritance specifier" ;
    rdfs:comment "General inheritance/delegation declaration. Includes delegation (Kotlin), trait bounds (Rust), interface embedding (Go)." ;
    rdfs:subClassOf sem:Inheritance .

<https://repolex.ai/ontology/repolex/gh-extension/Item> a owl:Class ;
    rdfs:label "Item" ;
    rdfs:comment "Abstract superclass for numbered, authored, timestamped GitHub entities (issues, pull requests, discussions). Enables cross-type queries without UNION." .

lsp-x:importTarget a owl:ObjectProperty ;
    rdfs:label "import target" ;
    rdfs:comment "The resolved location of an imported module/symbol, populated by multilspy LSP resolution." ;
    rdfs:domain ast:Node ;
    rdfs:range lsp:Location .

sem:Exception a owl:Class ;
    rdfs:label "Exception Handling" ;
    rdfs:comment "Exception handling constructs: try blocks, catch/except clauses, throw/raise statements. Used to find error handling patterns." .

sem:Inheritance a owl:Class ;
    rdfs:label "Inheritance" ;
    rdfs:comment "Inheritance and interface implementation relationships: extends, implements, inherits from, trait bounds. Used for OOP hierarchy analysis." .

ns1:Vulnerability a owl:Class ;
    rdfs:label "Vulnerability" ;
    rdfs:comment "A vulnerability describing the product and its affected versions within a GitHub Security Advisory." ;
    ns1:openApiSchemaName "vulnerability" .

lsp:MarkupKind a owl:Class ;
    rdfs:label "MarkupKind" ;
    rdfs:comment "Describes the content type supported in hover and completion results. Values: plaintext, markdown. (LSP v3.17.0: MarkupKind)" .

lsp:Position a owl:Class ;
    rdfs:label "Position" ;
    rdfs:comment "A position in a text document expressed as zero-based line and character offset. Both fields are zero-based integers. (LSP v3.17.0: Position)" .

ast:Point a owl:Class ;
    rdfs:label "Point" ;
    rdfs:comment "A position in source code, with row and column." .

repolex:GraphFile a owl:Class ;
    rdfs:label "Graph File" ;
    rdfs:comment "A serialized RDF graph file produced by the parser. Contains the path and size of a .nq.gz file in the storage repo." .

ast-x:ImplementsClause a owl:Class ;
    rdfs:label "implements clause" ;
    rdfs:comment "Interface implementation declaration. Maps to implements (Java, TypeScript), trait bounds (Rust), protocols (Swift)." ;
    rdfs:subClassOf sem:Inheritance .

sem:DataFlow a owl:Class ;
    rdfs:label "Data Flow" ;
    rdfs:comment "Data flow constructs: assignments, augmented assignments, parameters, variable declarations. Used to track how data moves through code." .

sem:Type a owl:Class ;
    rdfs:label "Type Definition" ;
    rdfs:comment "Type definitions: interfaces, enums, structs, type aliases, traits, protocols. Used to find type system elements across languages." .

ns1:DependabotAlert a owl:Class ;
    rdfs:label "DependabotAlert" ;
    rdfs:comment "A Dependabot alert." ;
    ns1:openApiSchemaName "dependabot-alert" .

ns1:DependabotAlertWithRepository a owl:Class ;
    rdfs:label "DependabotAlertWithRepository" ;
    rdfs:comment "A Dependabot alert." ;
    ns1:openApiSchemaName "dependabot-alert-with-repository" .

ns1:License a owl:Class ;
    rdfs:label "License" ;
    rdfs:comment "License Simple" ;
    ns1:openApiSchemaName "license-simple" .

git:Actor a owl:Class ;
    rdfs:label "Actor" ;
    rdfs:comment "A person who performed an action in git (author, committer, or tagger). Identified by name and email." .

git:Remote a owl:Class ;
    rdfs:label "Remote" ;
    rdfs:comment "A remote repository configuration (e.g., 'origin')." .

ast-x:AugmentedAssignment a owl:Class ;
    rdfs:label "augmented assignment" ;
    rdfs:comment "Compound assignment: +=, -=, *=, /=, etc. Reads and writes the same variable." ;
    rdfs:subClassOf sem:DataFlow,
        sem:Mutation .

ast-x:ElseClause a owl:Class ;
    rdfs:label "else clause" ;
    rdfs:comment "Default branch when no condition matches. NOT a decision point - does not contribute to cyclomatic complexity. Separated from ast-x:IfStatement to avoid inflating complexity counts." ;
    rdfs:subClassOf sem:ControlFlow .

ns1:Label a owl:Class ;
    rdfs:label "Label" ;
    rdfs:comment "Color-coded labels help you categorize and filter your issues (just like labels in Gmail)." ;
    owl:disjointWith ns1:Milestone ;
    ns1:openApiSchemaName "label" .

ns1:OrgMembership a owl:Class ;
    rdfs:label "OrgMembership" ;
    rdfs:comment "Org Membership" ;
    ns1:openApiSchemaName "org-membership" .

git:IndexObject a owl:Class ;
    rdfs:label "IndexObject" ;
    rdfs:comment "GitPython abstraction for objects that can appear in a tree index. Adds path, name, and mode information from the tree context. Parent class of Blob and Tree." ;
    rdfs:subClassOf git:Object .

git:Tree a owl:Class ;
    rdfs:label "Tree" ;
    rdfs:comment "A git tree object. Represents a directory - contains references to blobs (files) and other trees (subdirectories)." ;
    rdfs:subClassOf git:IndexObject ;
    owl:disjointWith git:Tag .

lsp:Range a owl:Class ;
    rdfs:label "Range" ;
    rdfs:comment "A range in a text document expressed as start and end positions. (LSP v3.17.0: Range)" .

comment: a owl:Ontology ;
    rdfs:label "Comment Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for comment" ;
    owl:versionInfo "v0.25" ;
    comment:abiVersion 15 ;
    comment:fieldCount 0 ;
    comment:languageName "comment" ;
    comment:nodeKindCount 35 .

ast-x:YieldStatement a owl:Class ;
    rdfs:label "yield statement" ;
    rdfs:comment "Generator/coroutine yield: yield, yield_expression, co_yield." ;
    rdfs:subClassOf sem:ControlFlow .

git:Repository a owl:Class ;
    rdfs:label "Repository" ;
    rdfs:comment "A git repository. Contains objects, references, and configuration." .

lsp:Location a owl:Class ;
    rdfs:label "Location" ;
    rdfs:comment "Represents a location inside a resource such as a line inside a text file. (LSP v3.17.0: Location, extended by multilspy with absolutePath and relativePath.)" .

csv: a owl:Ontology ;
    rdfs:label "Csv Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for csv" ;
    owl:versionInfo "v0.25" ;
    csv:abiVersion 14 ;
    csv:fieldCount 0 ;
    csv:languageName "None" ;
    csv:nodeKindCount 19 .

printf: a owl:Ontology ;
    rdfs:label "Printf Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for printf" ;
    owl:versionInfo "v0.25" ;
    printf:abiVersion 14 ;
    printf:fieldCount 0 ;
    printf:languageName "None" ;
    printf:nodeKindCount 13 .

psv: a owl:Ontology ;
    rdfs:label "Psv Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for psv" ;
    owl:versionInfo "v0.25" ;
    psv:abiVersion 14 ;
    psv:fieldCount 0 ;
    psv:languageName "None" ;
    psv:nodeKindCount 19 .

tsv: a owl:Ontology ;
    rdfs:label "Tsv Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for tsv" ;
    owl:versionInfo "v0.25" ;
    tsv:abiVersion 14 ;
    tsv:fieldCount 0 ;
    tsv:languageName "None" ;
    tsv:nodeKindCount 19 .

repolex:File a owl:Class ;
    rdfs:label "File" ;
    rdfs:comment "A file in a repository" .

ns1:AuthorAssociation a owl:Class ;
    rdfs:label "AuthorAssociation" ;
    rdfs:comment "How the author is associated with the repository." .

git:Object a owl:Class ;
    rdfs:label "Object" ;
    rdfs:comment "Base class for all Git objects. All git objects are identified by their SHA-1 hash." .

git:Tag a owl:Class ;
    rdfs:label "Tag" ;
    rdfs:comment "An annotated git tag. Contains tagger info, date, message, and points to a tagged object (usually a commit). Lightweight tags are just refs and don't have a Tag object." ;
    rdfs:subClassOf git:Object .

lsp:UnifiedSymbolInformation a owl:Class ;
    rdfs:label "UnifiedSymbolInformation" ;
    rdfs:comment "Information about a programming construct such as a variable, class, or function. Unifies LSP DocumentSymbol and SymbolInformation into a single type. Returned by request_document_symbols and request_workspace_symbol. (multilspy type: UnifiedSymbolInformation)" .

ini: a owl:Ontology ;
    rdfs:label "Ini Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for ini" ;
    owl:versionInfo "v0.25" ;
    ini:abiVersion 14 ;
    ini:fieldCount 1 ;
    ini:languageName "None" ;
    ini:nodeKindCount 19 .

