ast:prevSibling a owl:ObjectProperty ;
    rdfs:label "prevSibling" ;
    rdfs:comment "The previous sibling node" ;
    rdfs:domain ast:Node ;
    rdfs:range ast:Node .

ast:row a owl:DatatypeProperty ;
    rdfs:label "row" ;
    rdfs:comment "Row (line) number in source code (0-indexed)" ;
    rdfs:domain ast:Point ;
    rdfs:range xsd:nonNegativeInteger .

ast:startByte a owl:DatatypeProperty ;
    rdfs:label "startByte" ;
    rdfs:comment "Starting byte offset in source code (0-indexed)" ;
    rdfs:domain ast:Node ;
