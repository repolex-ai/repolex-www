@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tsv: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/tsv/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tsv:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

tsv:boolean a owl:Class ;
    rdfs:label "boolean" ;
    rdfs:isDefinedBy tsv: ;
    rdfs:subClassOf ast:Node ;
    tsv:isSupertype true ;
    tsv:nodeTypeId 15 .

tsv:document a owl:Class ;
    rdfs:label "document" ;
    rdfs:isDefinedBy tsv: ;
    rdfs:subClassOf ast:Node ;
    tsv:isSupertype true ;
    tsv:nodeTypeId 10 .

tsv:field a owl:Class ;
    rdfs:label "field" ;
    rdfs:isDefinedBy tsv: ;
    rdfs:subClassOf ast:Node ;
    tsv:isSupertype true ;
    tsv:nodeTypeId 12 .

tsv:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

tsv:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

tsv:float a owl:Class ;
    rdfs:label "float" ;
    rdfs:isDefinedBy tsv: ;
    rdfs:subClassOf ast:Node ;
    tsv:isSupertype true ;
    tsv:nodeTypeId 14 .

tsv:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

tsv:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

tsv:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

tsv:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

tsv:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

tsv:number a owl:Class ;
    rdfs:label "number" ;
    rdfs:isDefinedBy tsv: ;
    rdfs:subClassOf ast:Node ;
    tsv:isSupertype true ;
    tsv:nodeTypeId 13 .

tsv:row a owl:Class ;
    rdfs:label "row" ;
    rdfs:isDefinedBy tsv: ;
    rdfs:subClassOf ast:Node ;
    tsv:isSupertype true ;
    tsv:nodeTypeId 11 .

tsv:text a owl:Class ;
    rdfs:label "text" ;
    rdfs:isDefinedBy tsv: ;
    rdfs:subClassOf ast:Node ;
    tsv:isSupertype true ;
    tsv:nodeTypeId 3 .

tsv: a owl:Ontology ;
    rdfs:label "Tsv Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for tsv" ;
    owl:versionInfo "v0.25" ;
    tsv:abiVersion 14 ;
    tsv:fieldCount 0 ;
    tsv:languageName "None" ;
    tsv:nodeKindCount 19 .

