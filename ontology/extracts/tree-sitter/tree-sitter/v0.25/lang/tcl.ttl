tcl: a owl:Ontology ;
    rdfs:label "Tcl Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for tcl" ;
    owl:versionInfo "v0.25" ;
    tcl:abiVersion 15 ;
    tcl:fieldCount 7 ;
    tcl:languageName "tcl" ;
    tcl:nodeKindCount 120 .

