@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tcl: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/tcl/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tcl:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

tcl:argument a owl:Class ;
    rdfs:label "argument" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 93 .

tcl:arguments a owl:Class ;
    rdfs:label "arguments" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 94 .

tcl:array_index a owl:Class ;
    rdfs:label "array_index" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 86 .

tcl:binop_expr a owl:Class ;
    rdfs:label "binop_expr" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 99 .

tcl:body a owl:DatatypeProperty ;
    rdfs:label "body (literal)" ;
    rdfs:comment "Literal value for body field when it contains a terminal node" ;
    tcl:fieldId 3 ;
    tcl:isTerminalField true .

tcl:braced_word a owl:Class ;
    rdfs:label "braced_word" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 88 .

tcl:braced_word_simple a owl:Class ;
    rdfs:label "braced_word_simple" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 89 .

tcl:catch a owl:Class ;
    rdfs:label "catch" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 105 .

tcl:command a owl:Class ;
    rdfs:label "command" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 79 .

tcl:command_substitution a owl:Class ;
    rdfs:label "command_substitution" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 107 .

tcl:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 4 .

tcl:consequence a owl:DatatypeProperty ;
    rdfs:label "consequence (literal)" ;
    rdfs:comment "Literal value for consequence field when it contains a terminal node" ;
    tcl:fieldId 5 ;
    tcl:isTerminalField true .

tcl:default a owl:DatatypeProperty ;
    rdfs:label "default (literal)" ;
    rdfs:comment "Literal value for default field when it contains a terminal node" ;
    tcl:fieldId 6 ;
    tcl:isTerminalField true .

tcl:else a owl:Class ;
    rdfs:label "else" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 102 .

tcl:elseif a owl:Class ;
    rdfs:label "elseif" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 101 .

tcl:escaped_character a owl:Class ;
    rdfs:label "escaped_character" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 63 .

tcl:expr a owl:Class ;
    rdfs:label "expr" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 97 .

tcl:expr_cmd a owl:Class ;
    rdfs:label "expr_cmd" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 72 .

tcl:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

tcl:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

tcl:field_alternative a owl:ObjectProperty ;
    rdfs:label "alternative (structural)" ;
    rdfs:comment "Structural reference for alternative field when it contains a non-terminal node" ;
    tcl:fieldId 1 .

tcl:field_arguments a owl:ObjectProperty ;
    rdfs:label "arguments (structural)" ;
    rdfs:comment "Structural reference for arguments field when it contains a non-terminal node" ;
    tcl:fieldId 2 .

tcl:field_body a owl:ObjectProperty ;
    rdfs:label "body (structural)" ;
    rdfs:comment "Structural reference for body field when it contains a non-terminal node" ;
    tcl:fieldId 3 .

tcl:field_condition a owl:ObjectProperty ;
    rdfs:label "condition (structural)" ;
    rdfs:comment "Structural reference for condition field when it contains a non-terminal node" ;
    tcl:fieldId 4 .

tcl:field_consequence a owl:ObjectProperty ;
    rdfs:label "consequence (structural)" ;
    rdfs:comment "Structural reference for consequence field when it contains a non-terminal node" ;
    tcl:fieldId 5 .

tcl:field_default a owl:ObjectProperty ;
    rdfs:label "default (structural)" ;
    rdfs:comment "Structural reference for default field when it contains a non-terminal node" ;
    tcl:fieldId 6 .

tcl:field_name a owl:ObjectProperty ;
    rdfs:label "name (structural)" ;
    rdfs:comment "Structural reference for name field when it contains a non-terminal node" ;
    tcl:fieldId 7 .

tcl:finally a owl:Class ;
    rdfs:label "finally" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 77 .

tcl:foreach a owl:Class ;
    rdfs:label "foreach" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 73 .

tcl:global a owl:Class ;
    rdfs:label "global" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 74 .

tcl:id a owl:Class ;
    rdfs:label "id" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 84,
        85 .

tcl:if a owl:Class ;
    rdfs:label "if" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 103 .

tcl:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

tcl:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

tcl:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

tcl:name a owl:DatatypeProperty ;
    rdfs:label "name (literal)" ;
    rdfs:comment "Literal value for name field when it contains a terminal node" ;
    tcl:fieldId 7 ;
    tcl:isTerminalField true .

tcl:namespace a owl:Class ;
    rdfs:label "namespace" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 75 .

tcl:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

tcl:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

tcl:number a owl:Class ;
    rdfs:label "number" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 28 .

tcl:procedure a owl:Class ;
    rdfs:label "procedure" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 91 .

tcl:quoted_word a owl:Class ;
    rdfs:label "quoted_word" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 106 .

tcl:regexp a owl:Class ;
    rdfs:label "regexp" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 70 .

