    rdfs:label "set" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 90 .

tcl:simple_word a owl:Class ;
    rdfs:label "simple_word" ;
    rdfs:isDefinedBy tcl: ;
    rdfs:subClassOf ast:Node ;
    tcl:isSupertype true ;
    tcl:nodeTypeId 1 .

tcl:source_file a owl:Class ;
    rdfs:label "source_file" ;
    rdfs:isDefinedBy tcl: ;
