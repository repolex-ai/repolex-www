@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix clojure: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/clojure/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

clojure:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

clojure:anon_fn_lit a owl:Class ;
    rdfs:label "anon_fn_lit" ;
    rdfs:isDefinedBy clojure: ;
    rdfs:subClassOf ast:Node ;
    clojure:isSupertype true ;
    clojure:nodeTypeId 53 .

clojure:auto_res_mark a owl:Class ;
    rdfs:label "auto_res_mark" ;
    rdfs:isDefinedBy clojure: ;
    rdfs:subClassOf ast:Node ;
    clojure:isSupertype true ;
    clojure:nodeTypeId 57 .

