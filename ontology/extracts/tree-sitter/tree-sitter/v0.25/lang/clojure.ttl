clojure:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

clojure:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

clojure:field_close a owl:ObjectProperty ;
    rdfs:label "close (structural)" ;
    rdfs:comment "Structural reference for close field when it contains a non-terminal node" ;
    clojure:fieldId 1 .

clojure:field_delimiter a owl:ObjectProperty ;
    rdfs:label "delimiter (structural)" ;
    rdfs:comment "Structural reference for delimiter field when it contains a non-terminal node" ;
    clojure:fieldId 2 .

clojure:field_marker a owl:ObjectProperty ;
    rdfs:label "marker (structural)" ;
    rdfs:comment "Structural reference for marker field when it contains a non-terminal node" ;
    clojure:fieldId 3 .

clojure:field_meta a owl:ObjectProperty ;
    rdfs:label "meta (structural)" ;
    rdfs:comment "Structural reference for meta field when it contains a non-terminal node" ;
    clojure:fieldId 4 .

clojure:field_old_meta a owl:ObjectProperty ;
