@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix elixir: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/elixir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

elixir:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

elixir:access_call a owl:Class ;
    rdfs:label "access_call" ;
    rdfs:isDefinedBy elixir: ;
    rdfs:subClassOf ast:Node ;
    elixir:isSupertype true ;
    elixir:nodeTypeId 195 .

