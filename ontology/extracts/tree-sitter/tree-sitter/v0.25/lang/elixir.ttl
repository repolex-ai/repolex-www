elixir: a owl:Ontology ;
    rdfs:label "Elixir Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for elixir" ;
    owl:versionInfo "v0.25" ;
    elixir:abiVersion 14 ;
    elixir:fieldCount 9 ;
    elixir:languageName "None" ;
    elixir:nodeKindCount 235 .

