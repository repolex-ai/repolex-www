cmake:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

cmake:argument a owl:Class ;
    rdfs:label "argument" ;
    rdfs:isDefinedBy cmake: ;
    rdfs:subClassOf ast:Node ;
    cmake:isSupertype true ;
    cmake:nodeTypeId 54 .

