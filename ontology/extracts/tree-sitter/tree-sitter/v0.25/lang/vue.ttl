@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vue: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/vue/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

vue:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

vue:attribute a owl:Class ;
    rdfs:label "attribute" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 53 .

vue:attribute_name a owl:Class ;
    rdfs:label "attribute_name" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 9 .

vue:attribute_value a owl:Class ;
    rdfs:label "attribute_value" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 10,
        13,
        15 .

vue:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 37 .

vue:directive_attribute a owl:Class ;
    rdfs:label "directive_attribute" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 60 .

vue:directive_modifier a owl:Class ;
    rdfs:label "directive_modifier" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 29 .

vue:directive_modifiers a owl:Class ;
    rdfs:label "directive_modifiers" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 62 .

vue:directive_name a owl:Class ;
    rdfs:label "directive_name" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 23 .

vue:directive_value a owl:Class ;
    rdfs:label "directive_value" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 24 .

vue:doctype a owl:Class ;
    rdfs:label "doctype" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 42 .

vue:document a owl:Class ;
    rdfs:label "document" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 41 .

vue:dynamic_directive_inner_value a owl:Class ;
    rdfs:label "dynamic_directive_inner_value" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 27 .

vue:dynamic_directive_value a owl:Class ;
    rdfs:label "dynamic_directive_value" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 61 .

vue:element a owl:Class ;
    rdfs:label "element" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 44 .

vue:end_tag a owl:Class ;
    rdfs:label "end_tag" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 51 .

vue:entity a owl:Class ;
    rdfs:label "entity" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 11 .

vue:erroneous_end_tag a owl:Class ;
    rdfs:label "erroneous_end_tag" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 52 .

vue:erroneous_end_tag_name a owl:Class ;
    rdfs:label "erroneous_end_tag_name" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 34 .

vue:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

vue:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

vue:interpolation a owl:Class ;
    rdfs:label "interpolation" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 58 .

vue:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

vue:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

vue:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

vue:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

vue:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

vue:quoted_attribute_value a owl:Class ;
    rdfs:label "quoted_attribute_value" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 54 .

vue:raw_text a owl:Class ;
    rdfs:label "raw_text" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 36,
        40 .

vue:script_element a owl:Class ;
    rdfs:label "script_element" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 45 .

vue:self_closing_tag a owl:Class ;
    rdfs:label "self_closing_tag" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 50 .

vue:start_tag a owl:Class ;
    rdfs:label "start_tag" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 47,
        48,
        49,
        57 .

vue:style_element a owl:Class ;
    rdfs:label "style_element" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 46 .

vue:tag_name a owl:Class ;
    rdfs:label "tag_name" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 30,
        31,
        32,
        33,
        38 .

vue:template_element a owl:Class ;
    rdfs:label "template_element" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 56 .

vue:text a owl:Class ;
    rdfs:label "text" ;
    rdfs:isDefinedBy vue: ;
    rdfs:subClassOf ast:Node ;
    vue:isSupertype true ;
    vue:nodeTypeId 55 .

vue: a owl:Ontology ;
    rdfs:label "Vue Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for vue" ;
    owl:versionInfo "v0.25" ;
    vue:abiVersion 14 ;
    vue:fieldCount 0 ;
    vue:languageName "None" ;
    vue:nodeKindCount 67 .

