@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix doxygen: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/doxygen/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

doxygen:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

doxygen:brief_description a owl:Class ;
    rdfs:label "brief_description" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 3,
        49 .

doxygen:brief_header a owl:Class ;
    rdfs:label "brief_header" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 48 .

doxygen:brief_text a owl:Class ;
    rdfs:label "brief_text" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 42 .

doxygen:code a owl:Class ;
    rdfs:label "code" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 69 .

doxygen:code_block a owl:Class ;
    rdfs:label "code_block" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 60 .

doxygen:code_block_content a owl:Class ;
    rdfs:label "code_block_content" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 45 .

doxygen:code_block_end a owl:Class ;
    rdfs:label "code_block_end" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 46 .

doxygen:code_block_language a owl:Class ;
    rdfs:label "code_block_language" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 44 .

doxygen:code_block_start a owl:Class ;
    rdfs:label "code_block_start" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 43 .

doxygen:code_word a owl:Class ;
    rdfs:label "code_word" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 58 .

doxygen:description a owl:Class ;
    rdfs:label "description" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 50 .

doxygen:document a owl:Class ;
    rdfs:label "document" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 47 .

doxygen:emphasis a owl:Class ;
    rdfs:label "emphasis" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 57 .

doxygen:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

doxygen:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

doxygen:function a owl:Class,
        owl:DatatypeProperty ;
    rdfs:label "function",
        "function (literal)" ;
    rdfs:comment "Literal value for function field when it contains a terminal node" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:fieldId 1 ;
    doxygen:isSupertype true ;
    doxygen:isTerminalField true ;
    doxygen:nodeTypeId 55 .

doxygen:function_link a owl:Class ;
    rdfs:label "function_link" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 30 .

doxygen:identifier a owl:Class ;
    rdfs:label "identifier" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 53 .

doxygen:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

doxygen:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

doxygen:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

doxygen:link a owl:Class ;
    rdfs:label "link" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 59 .

doxygen:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

doxygen:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

doxygen:qualified_identifier a owl:Class ;
    rdfs:label "qualified_identifier" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 54 .

doxygen:storageclass a owl:Class ;
    rdfs:label "storageclass" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 56 .

doxygen:tag a owl:Class ;
    rdfs:label "tag" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 51 .

doxygen:tag_name a owl:Class ;
    rdfs:label "tag_name" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 1,
        2,
        7,
        8,
        9,
        10,
        11,
        12 .

doxygen:text a owl:Class ;
    rdfs:label "text" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 28 .

doxygen:type a owl:Class ;
    rdfs:label "type" ;
    rdfs:isDefinedBy doxygen: ;
    rdfs:subClassOf ast:Node ;
    doxygen:isSupertype true ;
    doxygen:nodeTypeId 6 .

doxygen: a owl:Ontology ;
    rdfs:label "Doxygen Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for doxygen" ;
    owl:versionInfo "v0.25" ;
    doxygen:abiVersion 14 ;
    doxygen:fieldCount 1 ;
    doxygen:languageName "None" ;
    doxygen:nodeKindCount 70 .

