@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix gitignore: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/gitignore/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

gitignore:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

gitignore:bracket_char a owl:Class ;
    rdfs:label "bracket_char" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 15 .

gitignore:bracket_char_class a owl:Class ;
    rdfs:label "bracket_char_class" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 47 .

gitignore:bracket_char_escaped a owl:Class ;
    rdfs:label "bracket_char_escaped" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 45 .

gitignore:bracket_expr a owl:Class ;
    rdfs:label "bracket_expr" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 39 .

gitignore:bracket_negation a owl:Class ;
    rdfs:label "bracket_negation" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 12 .

gitignore:bracket_range a owl:Class ;
    rdfs:label "bracket_range" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 43,
        46 .

gitignore:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 1 .

gitignore:directory_flag a owl:DatatypeProperty ;
    rdfs:label "directory_flag (literal)" ;
    rdfs:comment "Literal value for directory_flag field when it contains a terminal node" ;
    gitignore:fieldId 1 ;
    gitignore:isTerminalField true .

gitignore:directory_separator a owl:Class ;
    rdfs:label "directory_separator" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 3 .

gitignore:directory_separator_escaped a owl:Class ;
    rdfs:label "directory_separator_escaped" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 4 .

gitignore:document a owl:Class ;
    rdfs:label "document" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 32 .

gitignore:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

gitignore:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

gitignore:field_name a owl:ObjectProperty ;
    rdfs:label "name (structural)" ;
    rdfs:comment "Structural reference for name field when it contains a non-terminal node" ;
    gitignore:fieldId 2 .

gitignore:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

gitignore:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

gitignore:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

gitignore:negation a owl:Class ;
    rdfs:label "negation" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 2 .

gitignore:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

gitignore:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

gitignore:pattern a owl:Class ;
    rdfs:label "pattern" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 34 .

gitignore:pattern_char a owl:Class ;
    rdfs:label "pattern_char" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 5 .

gitignore:pattern_char_escaped a owl:Class ;
    rdfs:label "pattern_char_escaped" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 37 .

gitignore:relative_flag a owl:DatatypeProperty ;
    rdfs:label "relative_flag (literal)" ;
    rdfs:comment "Literal value for relative_flag field when it contains a terminal node" ;
    gitignore:fieldId 3 ;
    gitignore:isTerminalField true .

gitignore:wildcard_char_single a owl:Class ;
    rdfs:label "wildcard_char_single" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 8 .

gitignore:wildcard_chars a owl:Class ;
    rdfs:label "wildcard_chars" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 9 .

gitignore:wildcard_chars_allow_slash a owl:Class ;
    rdfs:label "wildcard_chars_allow_slash" ;
    rdfs:isDefinedBy gitignore: ;
    rdfs:subClassOf ast:Node ;
    gitignore:isSupertype true ;
    gitignore:nodeTypeId 10 .

gitignore: a owl:Ontology ;
    rdfs:label "Gitignore Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for gitignore" ;
    owl:versionInfo "v0.25" ;
    gitignore:abiVersion 13 ;
    gitignore:fieldCount 3 ;
    gitignore:languageName "None" ;
    gitignore:nodeKindCount 51 .

