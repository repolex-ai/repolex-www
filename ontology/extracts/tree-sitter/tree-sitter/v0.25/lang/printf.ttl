@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix printf: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/printf/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

printf:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

printf:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

printf:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

printf:flags a owl:Class ;
    rdfs:label "flags" ;
    rdfs:isDefinedBy printf: ;
    rdfs:subClassOf ast:Node ;
    printf:isSupertype true ;
    printf:nodeTypeId 4 .

printf:format a owl:Class ;
    rdfs:label "format" ;
    rdfs:isDefinedBy printf: ;
    rdfs:subClassOf ast:Node ;
    printf:isSupertype true ;
    printf:nodeTypeId 10 .

printf:format_string a owl:Class ;
    rdfs:label "format_string" ;
    rdfs:isDefinedBy printf: ;
    rdfs:subClassOf ast:Node ;
    printf:isSupertype true ;
    printf:nodeTypeId 9 .

printf:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

printf:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

printf:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

printf:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

printf:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

printf:precision a owl:Class ;
    rdfs:label "precision" ;
    rdfs:isDefinedBy printf: ;
    rdfs:subClassOf ast:Node ;
    printf:isSupertype true ;
    printf:nodeTypeId 6 .

printf:size a owl:Class ;
    rdfs:label "size" ;
    rdfs:isDefinedBy printf: ;
    rdfs:subClassOf ast:Node ;
    printf:isSupertype true ;
    printf:nodeTypeId 7 .

printf:type a owl:Class ;
    rdfs:label "type" ;
    rdfs:isDefinedBy printf: ;
    rdfs:subClassOf ast:Node ;
    printf:isSupertype true ;
    printf:nodeTypeId 3 .

printf:width a owl:Class ;
    rdfs:label "width" ;
    rdfs:isDefinedBy printf: ;
    rdfs:subClassOf ast:Node ;
    printf:isSupertype true ;
    printf:nodeTypeId 5 .

printf: a owl:Ontology ;
    rdfs:label "Printf Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for printf" ;
    owl:versionInfo "v0.25" ;
    printf:abiVersion 14 ;
    printf:fieldCount 0 ;
    printf:languageName "None" ;
    printf:nodeKindCount 13 .

