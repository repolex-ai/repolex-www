@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tablegen: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/tablegen/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tablegen:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

tablegen:argument a owl:DatatypeProperty ;
    rdfs:label "argument (literal)" ;
    rdfs:comment "Literal value for argument field when it contains a terminal node" ;
    tablegen:fieldId 1 ;
    tablegen:isTerminalField true .

tablegen:argument_list a owl:Class ;
    rdfs:label "argument_list" ;
    rdfs:isDefinedBy tablegen: ;
    rdfs:subClassOf ast:Node ;
    tablegen:isSupertype true ;
    tablegen:nodeTypeId 61 .

tablegen:assert a owl:Class ;
    rdfs:label "assert" ;
    rdfs:isDefinedBy tablegen: ;
    rdfs:subClassOf ast:Node ;
    tablegen:isSupertype true ;
    tablegen:nodeTypeId 81 .

tablegen:body_item a owl:Class ;
    rdfs:label "body_item" ;
    rdfs:isDefinedBy tablegen: ;
    rdfs:subClassOf ast:Node ;
    tablegen:isSupertype true ;
    tablegen:nodeTypeId 65 .

tablegen:class a owl:Class ;
    rdfs:label "class" ;
    rdfs:isDefinedBy tablegen: ;
