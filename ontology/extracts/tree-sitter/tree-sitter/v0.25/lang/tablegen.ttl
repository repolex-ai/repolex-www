tablegen:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

tablegen:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

tablegen:field_argument a owl:ObjectProperty ;
    rdfs:label "argument (structural)" ;
    rdfs:comment "Structural reference for argument field when it contains a non-terminal node" ;
    tablegen:fieldId 1 .

tablegen:field_body a owl:ObjectProperty ;
    rdfs:label "body (structural)" ;
    rdfs:comment "Structural reference for body field when it contains a non-terminal node" ;
    tablegen:fieldId 2 .

tablegen:file a owl:Class ;
    rdfs:label "file" ;
    rdfs:isDefinedBy tablegen: ;
    rdfs:subClassOf ast:Node ;
    tablegen:isSupertype true ;
    tablegen:nodeTypeId 55 .

tablegen:foreach a owl:Class ;
    rdfs:label "foreach" ;
    rdfs:isDefinedBy tablegen: ;
