tablegen: a owl:Ontology ;
    rdfs:label "Tablegen Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for tablegen" ;
    owl:versionInfo "v0.25" ;
    tablegen:abiVersion 14 ;
    tablegen:fieldCount 3 ;
    tablegen:languageName "None" ;
    tablegen:nodeKindCount 105 .

