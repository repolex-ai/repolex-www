luadoc:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

luadoc:alias_annotation a owl:Class ;
    rdfs:label "alias_annotation" ;
