@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix heex: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/heex/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

heex:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

heex:attribute a owl:Class ;
    rdfs:label "attribute" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 64 .

heex:attribute_name a owl:Class ;
    rdfs:label "attribute_name" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 43 .

heex:attribute_value a owl:Class ;
    rdfs:label "attribute_value" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 18,
        20,
        22 .

heex:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 67 .

heex:component a owl:Class ;
    rdfs:label "component" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 49 .

heex:component_name a owl:Class ;
    rdfs:label "component_name" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 74 .

heex:directive a owl:Class ;
    rdfs:label "directive" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 66 .

heex:doctype a owl:Class ;
    rdfs:label "doctype" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 47 .

heex:end_component a owl:Class ;
    rdfs:label "end_component" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 55 .

heex:end_slot a owl:Class ;
    rdfs:label "end_slot" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 58 .

heex:end_tag a owl:Class ;
    rdfs:label "end_tag" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 52 .

heex:ending_expression_value a owl:Class ;
    rdfs:label "ending_expression_value" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 73 .

heex:expression a owl:Class ;
    rdfs:label "expression" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 60 .

heex:expression_value a owl:Class ;
    rdfs:label "expression_value" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 71 .

heex:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

heex:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

heex:fragment a owl:Class ;
    rdfs:label "fragment" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 45 .

heex:function a owl:Class ;
    rdfs:label "function" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 40 .

heex:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

heex:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

heex:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

heex:module a owl:Class ;
    rdfs:label "module" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 39 .

heex:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

heex:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

heex:partial_expression_value a owl:Class ;
    rdfs:label "partial_expression_value" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 72 .

heex:quoted_attribute_value a owl:Class ;
    rdfs:label "quoted_attribute_value" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 65 .

heex:self_closing_component a owl:Class ;
    rdfs:label "self_closing_component" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 56 .

heex:self_closing_slot a owl:Class ;
    rdfs:label "self_closing_slot" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 59 .

heex:self_closing_tag a owl:Class ;
    rdfs:label "self_closing_tag" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 53 .

heex:slot a owl:Class ;
    rdfs:label "slot" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 50 .

heex:slot_name a owl:Class ;
    rdfs:label "slot_name" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 83 .

heex:special_attribute a owl:Class ;
    rdfs:label "special_attribute" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 62 .

heex:special_attribute_name a owl:Class ;
    rdfs:label "special_attribute_name" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 63 .

heex:start_component a owl:Class ;
    rdfs:label "start_component" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 54 .

heex:start_slot a owl:Class ;
    rdfs:label "start_slot" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 57 .

heex:start_tag a owl:Class ;
    rdfs:label "start_tag" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 51 .

heex:tag a owl:Class ;
    rdfs:label "tag" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 48 .

heex:tag_name a owl:Class ;
    rdfs:label "tag_name" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 42 .

heex:text a owl:Class ;
    rdfs:label "text" ;
    rdfs:isDefinedBy heex: ;
    rdfs:subClassOf ast:Node ;
    heex:isSupertype true ;
    heex:nodeTypeId 44 .

heex: a owl:Ontology ;
    rdfs:label "Heex Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for heex" ;
    owl:versionInfo "v0.25" ;
    heex:abiVersion 14 ;
    heex:fieldCount 0 ;
    heex:languageName "None" ;
    heex:nodeKindCount 84 .

