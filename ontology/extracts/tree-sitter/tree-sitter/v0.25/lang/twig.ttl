twig:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

twig:argument a owl:Class ;
    rdfs:label "argument" ;
    rdfs:isDefinedBy twig: ;
    rdfs:subClassOf ast:Node ;
    twig:isSupertype true ;
    twig:nodeTypeId 118,
        122 .

