@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix hyprlang: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/hyprlang/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hyprlang:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

hyprlang:angle a owl:Class ;
    rdfs:label "angle" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 79 .

hyprlang:arguments a owl:Class ;
    rdfs:label "arguments" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 64 .

hyprlang:assignment a owl:Class ;
    rdfs:label "assignment" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 60 .

hyprlang:boolean a owl:Class ;
    rdfs:label "boolean" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 69 .

hyprlang:color a owl:Class ;
    rdfs:label "color" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 72 .

hyprlang:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy hyprlang: ;
