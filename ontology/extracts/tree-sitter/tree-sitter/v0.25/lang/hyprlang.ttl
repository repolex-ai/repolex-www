    rdfs:label "rgb" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 74 .

hyprlang:rules a owl:Class ;
    rdfs:label "rules" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 66 .

hyprlang:section a owl:Class ;
    rdfs:label "section" ;
    rdfs:isDefinedBy hyprlang: ;
