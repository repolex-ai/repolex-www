hyprlang:source a owl:Class ;
    rdfs:label "source" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 63 .

hyprlang:string a owl:Class ;
    rdfs:label "string" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 1,
        54 .

hyprlang:string_literal a owl:Class ;
    rdfs:label "string_literal" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
