    rdfs:label "mod" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 80 .

hyprlang:name a owl:Class,
        owl:DatatypeProperty ;
    rdfs:label "name",
        "name (literal)" ;
    rdfs:comment "Literal value for name field when it contains a terminal node" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:fieldId 3 ;
    hyprlang:isSupertype true ;
    hyprlang:isTerminalField true ;
    hyprlang:nodeTypeId 49 .

hyprlang:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

hyprlang:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

hyprlang:number a owl:Class ;
    rdfs:label "number" ;
    rdfs:isDefinedBy hyprlang: ;
