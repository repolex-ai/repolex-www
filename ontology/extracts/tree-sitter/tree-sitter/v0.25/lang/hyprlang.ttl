hyprlang:value a owl:DatatypeProperty ;
    rdfs:label "value (literal)" ;
    rdfs:comment "Literal value for value field when it contains a terminal node" ;
    hyprlang:fieldId 4 ;
    hyprlang:isTerminalField true .

hyprlang:variable a owl:Class ;
    rdfs:label "variable" ;
    rdfs:isDefinedBy hyprlang: ;
