hyprlang: a owl:Ontology ;
    rdfs:label "Hyprlang Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for hyprlang" ;
    owl:versionInfo "v0.25" ;
    hyprlang:abiVersion 15 ;
    hyprlang:fieldCount 4 ;
    hyprlang:languageName "hyprlang" ;
    hyprlang:nodeKindCount 94 .

