    hyprlang:nodeTypeId 58 .

hyprlang:declaration a owl:Class ;
    rdfs:label "declaration" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 59 .

hyprlang:device a owl:DatatypeProperty ;
    rdfs:label "device (literal)" ;
    rdfs:comment "Literal value for device field when it contains a terminal node" ;
    hyprlang:fieldId 1 ;
    hyprlang:isTerminalField true .

hyprlang:device_name a owl:Class ;
    rdfs:label "device_name" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 50 .

hyprlang:display a owl:Class ;
    rdfs:label "display" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 77 .

hyprlang:exec a owl:Class ;
    rdfs:label "exec" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 67 .

hyprlang:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

hyprlang:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

hyprlang:field_value a owl:ObjectProperty ;
    rdfs:label "value (structural)" ;
    rdfs:comment "Structural reference for value field when it contains a non-terminal node" ;
    hyprlang:fieldId 4 .

hyprlang:gradient a owl:Class ;
    rdfs:label "gradient" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 75 .

hyprlang:hex a owl:Class ;
    rdfs:label "hex" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 31 .

hyprlang:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

hyprlang:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

hyprlang:keys a owl:Class ;
    rdfs:label "keys" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:isSupertype true ;
    hyprlang:nodeTypeId 81 .

hyprlang:keyword a owl:Class,
        owl:DatatypeProperty ;
    rdfs:label "keyword",
        "keyword (literal)" ;
    rdfs:comment "Literal value for keyword field when it contains a terminal node" ;
    rdfs:isDefinedBy hyprlang: ;
    rdfs:subClassOf ast:Node ;
    hyprlang:fieldId 2 ;
    hyprlang:isSupertype true ;
    hyprlang:isTerminalField true ;
    hyprlang:nodeTypeId 61 .

hyprlang:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

hyprlang:legacy_hex a owl:Class ;
