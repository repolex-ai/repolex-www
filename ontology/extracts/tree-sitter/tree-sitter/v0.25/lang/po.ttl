@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix po: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/po/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

po:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

po:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 28 .

po:escape_sequence a owl:Class ;
    rdfs:label "escape_sequence" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 19 .

po:extracted_comment a owl:Class ;
    rdfs:label "extracted_comment" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 30 .

po:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

po:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

po:flag a owl:Class ;
    rdfs:label "flag" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 32 .

po:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

po:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

po:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

po:message a owl:Class ;
    rdfs:label "message" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 22 .

po:msgctxt a owl:Class ;
    rdfs:label "msgctxt" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 23 .

po:msgid a owl:Class ;
    rdfs:label "msgid" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 24 .

po:msgid_plural a owl:Class ;
    rdfs:label "msgid_plural" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 25 .

po:msgstr a owl:Class ;
    rdfs:label "msgstr" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 26 .

po:msgstr_plural a owl:Class ;
    rdfs:label "msgstr_plural" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 27 .

po:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

po:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

po:number a owl:Class ;
    rdfs:label "number" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 15 .

po:previous_untranslated_string a owl:Class ;
    rdfs:label "previous_untranslated_string" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 33 .

po:reference a owl:Class ;
    rdfs:label "reference" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 31 .

po:source_file a owl:Class ;
    rdfs:label "source_file" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 21 .

po:string a owl:Class ;
    rdfs:label "string" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 34 .

po:string_fragment a owl:Class ;
    rdfs:label "string_fragment" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 17 .

po:text a owl:Class ;
    rdfs:label "text" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 20 .

po:translator_comment a owl:Class ;
    rdfs:label "translator_comment" ;
    rdfs:isDefinedBy po: ;
    rdfs:subClassOf ast:Node ;
    po:isSupertype true ;
    po:nodeTypeId 29 .

po: a owl:Ontology ;
    rdfs:label "Po Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for po" ;
    owl:versionInfo "v0.25" ;
    po:abiVersion 14 ;
    po:fieldCount 0 ;
    po:languageName "None" ;
    po:nodeKindCount 40 .

