@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix luap: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/luap/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

luap:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

luap:anchor_begin a owl:Class ;
    rdfs:label "anchor_begin" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 22 .

luap:anchor_end a owl:Class ;
    rdfs:label "anchor_end" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 23 .

luap:balanced_match a owl:Class ;
    rdfs:label "balanced_match" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 26 .

luap:capture a owl:Class ;
    rdfs:label "capture" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 34 .

luap:capture_index a owl:Class ;
    rdfs:label "capture_index" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 6 .

luap:character a owl:Class ;
    rdfs:label "character" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 8,
        16,
        25 .

luap:class a owl:Class ;
    rdfs:label "class" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 29 .

luap:class_pattern a owl:Class ;
    rdfs:label "class_pattern" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 30 .

luap:escape_char a owl:Class ;
    rdfs:label "escape_char" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 5 .

luap:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

luap:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

luap:field_first a owl:ObjectProperty ;
    rdfs:label "first (structural)" ;
    rdfs:comment "Structural reference for first field when it contains a non-terminal node" ;
    luap:fieldId 1 .

luap:field_from a owl:ObjectProperty ;
    rdfs:label "from (structural)" ;
    rdfs:comment "Structural reference for from field when it contains a non-terminal node" ;
    luap:fieldId 2 .

luap:field_last a owl:ObjectProperty ;
    rdfs:label "last (structural)" ;
    rdfs:comment "Structural reference for last field when it contains a non-terminal node" ;
    luap:fieldId 3 .

luap:field_to a owl:ObjectProperty ;
    rdfs:label "to (structural)" ;
    rdfs:comment "Structural reference for to field when it contains a non-terminal node" ;
    luap:fieldId 4 .

luap:frontier_pattern a owl:Class ;
    rdfs:label "frontier_pattern" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 27 .

luap:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

luap:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

luap:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

luap:negated_set a owl:Class ;
    rdfs:label "negated_set" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 33 .

luap:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

luap:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

luap:one_or_more a owl:Class ;
    rdfs:label "one_or_more" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 12 .

luap:pattern a owl:Class ;
    rdfs:label "pattern" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 21 .

luap:range a owl:Class ;
    rdfs:label "range" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 31 .

luap:set a owl:Class ;
    rdfs:label "set" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 32 .

luap:shortest_zero_or_more a owl:Class ;
    rdfs:label "shortest_zero_or_more" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 28 .

luap:zero_or_more a owl:Class ;
    rdfs:label "zero_or_more" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 10 .

luap:zero_or_one a owl:Class ;
    rdfs:label "zero_or_one" ;
    rdfs:isDefinedBy luap: ;
    rdfs:subClassOf ast:Node ;
    luap:isSupertype true ;
    luap:nodeTypeId 13 .

luap: a owl:Ontology ;
    rdfs:label "Luap Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for luap" ;
    owl:versionInfo "v0.25" ;
    luap:abiVersion 14 ;
    luap:fieldCount 4 ;
    luap:languageName "None" ;
    luap:nodeKindCount 38 .

