@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

svelte:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

svelte:as a owl:Class ;
    rdfs:label "as" ;
    rdfs:isDefinedBy svelte: ;
    rdfs:subClassOf ast:Node ;
    svelte:isSupertype true ;
    svelte:nodeTypeId 30 .

