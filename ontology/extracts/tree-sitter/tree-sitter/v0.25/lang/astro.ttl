@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix astro: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/astro/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

astro:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

astro:attribute a owl:Class ;
    rdfs:label "attribute" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 48 .

astro:attribute_backtick_string a owl:Class ;
    rdfs:label "attribute_backtick_string" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 33 .

astro:attribute_interpolation a owl:Class ;
    rdfs:label "attribute_interpolation" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 52 .

astro:attribute_js_expr a owl:Class ;
    rdfs:label "attribute_js_expr" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 32 .

astro:attribute_name a owl:Class ;
    rdfs:label "attribute_name" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 9 .

astro:attribute_value a owl:Class ;
    rdfs:label "attribute_value" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 10,
        13,
        15 .

astro:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 28 .

astro:doctype a owl:Class ;
    rdfs:label "doctype" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 37 .

astro:document a owl:Class ;
    rdfs:label "document" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 36 .

astro:element a owl:Class ;
    rdfs:label "element" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 39 .

astro:end_tag a owl:Class ;
    rdfs:label "end_tag" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 46 .

astro:entity a owl:Class ;
    rdfs:label "entity" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 11 .

astro:erroneous_end_tag a owl:Class ;
    rdfs:label "erroneous_end_tag" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 47 .

astro:erroneous_end_tag_name a owl:Class ;
    rdfs:label "erroneous_end_tag_name" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 25 .

astro:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

astro:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

astro:frontmatter a owl:Class ;
    rdfs:label "frontmatter" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 51 .

astro:frontmatter_js_block a owl:Class ;
    rdfs:label "frontmatter_js_block" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 31 .

astro:html_interpolation a owl:Class ;
    rdfs:label "html_interpolation" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 53 .

astro:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

astro:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

astro:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

astro:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

astro:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

astro:permissible_text a owl:Class ;
    rdfs:label "permissible_text" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 34 .

astro:quoted_attribute_value a owl:Class ;
    rdfs:label "quoted_attribute_value" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 49 .

astro:raw_text a owl:Class ;
    rdfs:label "raw_text" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 27 .

astro:script_element a owl:Class ;
    rdfs:label "script_element" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 40 .

astro:self_closing_tag a owl:Class ;
    rdfs:label "self_closing_tag" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 45,
        54,
        55 .

astro:start_tag a owl:Class ;
    rdfs:label "start_tag" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 42,
        43,
        44 .

astro:style_element a owl:Class ;
    rdfs:label "style_element" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 41 .

astro:tag_name a owl:Class ;
    rdfs:label "tag_name" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 21,
        22,
        23,
        24 .

astro:text a owl:Class ;
    rdfs:label "text" ;
    rdfs:isDefinedBy astro: ;
    rdfs:subClassOf ast:Node ;
    astro:isSupertype true ;
    astro:nodeTypeId 16 .

astro: a owl:Ontology ;
    rdfs:label "Astro Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for astro" ;
    owl:versionInfo "v0.25" ;
    astro:abiVersion 14 ;
    astro:fieldCount 0 ;
    astro:languageName "None" ;
    astro:nodeKindCount 59 .

