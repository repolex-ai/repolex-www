@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

janet:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

janet:array a owl:Class ;
    rdfs:label "array" ;
    rdfs:isDefinedBy janet: ;
    rdfs:subClassOf ast:Node ;
    janet:isSupertype true ;
    janet:nodeTypeId 54 .

