@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pymanifest: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/pymanifest/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pymanifest:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

pymanifest:char_range a owl:Class ;
    rdfs:label "char_range" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 39 .

pymanifest:char_sequence a owl:Class ;
    rdfs:label "char_sequence" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 38 .

pymanifest:command a owl:Class ;
    rdfs:label "command" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 24 .

pymanifest:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 22 .

pymanifest:dir_sep a owl:Class ;
    rdfs:label "dir_sep" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 14 .

pymanifest:escaped_char a owl:Class ;
    rdfs:label "escaped_char" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 37 .

pymanifest:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

pymanifest:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

pymanifest:field_dir_pattern a owl:ObjectProperty ;
    rdfs:label "dir_pattern (structural)" ;
    rdfs:comment "Structural reference for dir_pattern field when it contains a non-terminal node" ;
    pymanifest:fieldId 1 .

pymanifest:glob a owl:Class ;
    rdfs:label "glob" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 13 .

pymanifest:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

pymanifest:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

pymanifest:keyword a owl:Class ;
    rdfs:label "keyword" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 1,
        2,
        3,
        4,
        5,
        6,
        7,
        8 .

pymanifest:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

pymanifest:linebreak a owl:Class ;
    rdfs:label "linebreak" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 34 .

pymanifest:manifest a owl:Class ;
    rdfs:label "manifest" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 23 .

pymanifest:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

pymanifest:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

pymanifest:pattern a owl:Class ;
    rdfs:label "pattern" ;
    rdfs:isDefinedBy pymanifest: ;
    rdfs:subClassOf ast:Node ;
    pymanifest:isSupertype true ;
    pymanifest:nodeTypeId 35 .

pymanifest: a owl:Ontology ;
    rdfs:label "Pymanifest Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for pymanifest" ;
    owl:versionInfo "v0.25" ;
    pymanifest:abiVersion 14 ;
    pymanifest:fieldCount 1 ;
    pymanifest:languageName "None" ;
    pymanifest:nodeKindCount 45 .

