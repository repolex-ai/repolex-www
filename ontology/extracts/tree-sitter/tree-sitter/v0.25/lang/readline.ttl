readline: a owl:Ontology ;
    rdfs:label "Readline Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for readline" ;
    owl:versionInfo "v0.25" ;
    readline:abiVersion 14 ;
    readline:fieldCount 0 ;
    readline:languageName "None" ;
    readline:nodeKindCount 146 .

