    rdfs:subClassOf ast:Node ;
    readline:isSupertype true ;
    readline:nodeTypeId 105 .

readline:conditional_construct a owl:Class ;
    rdfs:label "conditional_construct" ;
    rdfs:isDefinedBy readline: ;
    rdfs:subClassOf ast:Node ;
    readline:isSupertype true ;
    readline:nodeTypeId 106 .

readline:consequence a owl:Class ;
    rdfs:label "consequence" ;
    rdfs:isDefinedBy readline: ;
    rdfs:subClassOf ast:Node ;
    readline:isSupertype true ;
    readline:nodeTypeId 144 .

readline:edit_mode_value a owl:Class ;
    rdfs:label "edit_mode_value" ;
