@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix readline: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/readline/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

readline:ERROR a owl:Class ;
    rdfs:label "ERROR" ;
    rdfs:isDefinedBy readline: ;
    rdfs:subClassOf ast:Node ;
    readline:isSupertype true ;
    readline:nodeTypeId 27 .

readline:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

readline:alternative a owl:Class ;
    rdfs:label "alternative" ;
    rdfs:isDefinedBy readline: ;
    rdfs:subClassOf ast:Node ;
    readline:isSupertype true ;
    readline:nodeTypeId 143 .

readline:application_name a owl:Class ;
    rdfs:label "application_name" ;
    rdfs:isDefinedBy readline: ;
    rdfs:subClassOf ast:Node ;
    readline:isSupertype true ;
    readline:nodeTypeId 20 .

readline:bell_value a owl:Class ;
    rdfs:label "bell_value" ;
