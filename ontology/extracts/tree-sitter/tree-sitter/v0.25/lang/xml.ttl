xml1:field_root a owl:ObjectProperty ;
    rdfs:label "root (structural)" ;
    rdfs:comment "Structural reference for root field when it contains a non-terminal node" ;
    xml1:fieldId 2 .

xml1:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
