    dtd:isSupertype true ;
    dtd:nodeTypeId 25 .

dtd:URI a owl:Class ;
    rdfs:label "URI" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 49,
        50 .

dtd:VersionNum a owl:Class ;
    rdfs:label "VersionNum" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 54 .

dtd:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

dtd:children a owl:Class ;
    rdfs:label "children" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 70 .

dtd:conditionalSect a owl:Class ;
    rdfs:label "conditionalSect" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 64 .

dtd:contentspec a owl:Class ;
    rdfs:label "contentspec" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 68 .

dtd:elementdecl a owl:Class ;
    rdfs:label "elementdecl" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 67 .

dtd:extSubset a owl:Class ;
    rdfs:label "extSubset" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 61 .

dtd:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

dtd:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

dtd:field_content a owl:ObjectProperty ;
    rdfs:label "content (structural)" ;
    rdfs:comment "Structural reference for content field when it contains a non-terminal node" ;
    dtd:fieldId 1 .

dtd:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

dtd:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

dtd:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

dtd:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

dtd:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

dtd: a owl:Ontology ;
    rdfs:label "Dtd Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for dtd" ;
    owl:versionInfo "v0.25" ;
    dtd:abiVersion 14 ;
    dtd:fieldCount 1 ;
    dtd:languageName "None" ;
    dtd:nodeKindCount 111 .

