    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 24 .

dtd:SystemLiteral a owl:Class ;
    rdfs:label "SystemLiteral" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 93 .

dtd:TextDecl a owl:Class ;
