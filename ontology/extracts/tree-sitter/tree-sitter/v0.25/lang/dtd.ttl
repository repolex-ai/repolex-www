@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix dtd: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/dtd/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dtd:AttDef a owl:Class ;
    rdfs:label "AttDef" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 74 .

dtd:AttValue a owl:Class ;
    rdfs:label "AttValue" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 90 .

