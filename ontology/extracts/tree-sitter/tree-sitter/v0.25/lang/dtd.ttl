    dtd:nodeTypeId 82 .

dtd:PEReference a owl:Class ;
    rdfs:label "PEReference" ;
    rdfs:isDefinedBy dtd: ;
    rdfs:subClassOf ast:Node ;
    dtd:isSupertype true ;
    dtd:nodeTypeId 86 .

dtd:PI a owl:Class ;
    rdfs:label "PI" ;
    rdfs:isDefinedBy dtd: ;
