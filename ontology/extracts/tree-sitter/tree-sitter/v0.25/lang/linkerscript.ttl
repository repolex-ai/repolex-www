linkerscript: a owl:Ontology ;
    rdfs:label "Linkerscript Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for linkerscript" ;
    owl:versionInfo "v0.25" ;
    linkerscript:abiVersion 14 ;
    linkerscript:fieldCount 16 ;
    linkerscript:languageName "None" ;
    linkerscript:nodeKindCount 112 .

