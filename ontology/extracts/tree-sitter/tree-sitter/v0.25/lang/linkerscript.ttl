@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix linkerscript: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/linkerscript/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

linkerscript:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

linkerscript:argument_list a owl:Class ;
    rdfs:label "argument_list" ;
    rdfs:isDefinedBy linkerscript: ;
    rdfs:subClassOf ast:Node ;
    linkerscript:isSupertype true ;
    linkerscript:nodeTypeId 100 .

linkerscript:assert_command a owl:Class ;
    rdfs:label "assert_command" ;
    rdfs:isDefinedBy linkerscript: ;
    rdfs:subClassOf ast:Node ;
    linkerscript:isSupertype true ;
    linkerscript:nodeTypeId 86 .

linkerscript:assignment a owl:Class ;
    rdfs:label "assignment" ;
    rdfs:isDefinedBy linkerscript: ;
    rdfs:subClassOf ast:Node ;
    linkerscript:isSupertype true ;
    linkerscript:nodeTypeId 85 .

linkerscript:attributes a owl:Class ;
    rdfs:label "attributes" ;
    rdfs:isDefinedBy linkerscript: ;
