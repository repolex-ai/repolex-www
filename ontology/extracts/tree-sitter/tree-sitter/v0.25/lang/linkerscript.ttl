    rdfs:label "filename" ;
    rdfs:isDefinedBy linkerscript: ;
    rdfs:subClassOf ast:Node ;
    linkerscript:isSupertype true ;
    linkerscript:nodeTypeId 68 .

linkerscript:fillexp a owl:Class ;
    rdfs:label "fillexp" ;
    rdfs:isDefinedBy linkerscript: ;
