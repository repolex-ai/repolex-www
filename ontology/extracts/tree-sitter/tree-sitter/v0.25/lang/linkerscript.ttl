    linkerscript:fieldId 8 .

linkerscript:field_length a owl:ObjectProperty ;
    rdfs:label "length (structural)" ;
    rdfs:comment "Structural reference for length field when it contains a non-terminal node" ;
    linkerscript:fieldId 9 .

linkerscript:field_operator a owl:ObjectProperty ;
    rdfs:label "operator (structural)" ;
    rdfs:comment "Structural reference for operator field when it contains a non-terminal node" ;
