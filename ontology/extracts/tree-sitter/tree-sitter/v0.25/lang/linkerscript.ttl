    linkerscript:isSupertype true ;
    linkerscript:nodeTypeId 95 .

linkerscript:entry_command a owl:Class ;
    rdfs:label "entry_command" ;
    rdfs:isDefinedBy linkerscript: ;
    rdfs:subClassOf ast:Node ;
    linkerscript:isSupertype true ;
    linkerscript:nodeTypeId 71 .

linkerscript:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

linkerscript:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

linkerscript:field_address a owl:ObjectProperty ;
    rdfs:label "address (structural)" ;
    rdfs:comment "Structural reference for address field when it contains a non-terminal node" ;
    linkerscript:fieldId 1 .

