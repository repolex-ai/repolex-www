firrtl:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

firrtl:attach a owl:Class ;
    rdfs:label "attach" ;
