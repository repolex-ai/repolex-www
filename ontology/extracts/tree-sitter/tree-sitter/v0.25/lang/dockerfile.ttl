@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dockerfile:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

dockerfile:add_instruction a owl:Class ;
    rdfs:label "add_instruction" ;
    rdfs:isDefinedBy dockerfile: ;
    rdfs:subClassOf ast:Node ;
    dockerfile:isSupertype true ;
    dockerfile:nodeTypeId 95 .

