@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix dockerfile: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/dockerfile/> .
