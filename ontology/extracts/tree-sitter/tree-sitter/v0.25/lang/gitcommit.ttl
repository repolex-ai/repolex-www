gitcommit: a owl:Ontology ;
    rdfs:label "Gitcommit Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for gitcommit" ;
    owl:versionInfo "v0.25" ;
    gitcommit:abiVersion 14 ;
    gitcommit:fieldCount 1 ;
    gitcommit:languageName "None" ;
    gitcommit:nodeKindCount 495 .

