        467,
        480 .

gitcommit:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

gitcommit:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

gitcommit:kind a owl:DatatypeProperty ;
    rdfs:label "kind (literal)" ;
    rdfs:comment "Literal value for kind field when it contains a terminal node" ;
    gitcommit:fieldId 1 ;
    gitcommit:isTerminalField true .

gitcommit:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

gitcommit:message a owl:Class ;
    rdfs:label "message" ;
    rdfs:isDefinedBy gitcommit: ;
    rdfs:subClassOf ast:Node ;
    gitcommit:isSupertype true ;
    gitcommit:nodeTypeId 494 .

gitcommit:message_line a owl:Class ;
    rdfs:label "message_line" ;
    rdfs:isDefinedBy gitcommit: ;
    rdfs:subClassOf ast:Node ;
    gitcommit:isSupertype true ;
    gitcommit:nodeTypeId 462 .

