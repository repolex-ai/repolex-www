nix:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

nix:apply_expression a owl:Class ;
    rdfs:label "apply_expression" ;
    rdfs:isDefinedBy nix: ;
    rdfs:subClassOf ast:Node ;
    nix:isSupertype true ;
    nix:nodeTypeId 81 .

