@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix test: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/test/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

test:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

test:attribute a owl:Class ;
    rdfs:label "attribute" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 21 .

test:attributes a owl:Class ;
    rdfs:label "attributes" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 20 .

test:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

test:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

test:field_cst a owl:ObjectProperty ;
    rdfs:label "cst (structural)" ;
    rdfs:comment "Structural reference for cst field when it contains a non-terminal node" ;
    test:fieldId 1 .

test:file a owl:Class ;
    rdfs:label "file" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 16 .

test:header a owl:Class ;
    rdfs:label "header" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 19 .

test:input a owl:Class ;
    rdfs:label "input" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 26 .

test:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

test:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

test:language a owl:DatatypeProperty ;
    rdfs:label "language (literal)" ;
    rdfs:comment "Literal value for language field when it contains a terminal node" ;
    test:fieldId 2 ;
    test:isTerminalField true .

test:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

test:name a owl:Class ;
    rdfs:label "name" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 27 .

test:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

test:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

test:output a owl:Class ;
    rdfs:label "output" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 28 .

test:parameter a owl:Class ;
    rdfs:label "parameter" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 10,
        11 .

test:platform a owl:DatatypeProperty ;
    rdfs:label "platform (literal)" ;
    rdfs:comment "Literal value for platform field when it contains a terminal node" ;
    test:fieldId 3 ;
    test:isTerminalField true .

test:separator a owl:Class ;
    rdfs:label "separator" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 13,
        14,
        15 .

test:test a owl:Class ;
    rdfs:label "test" ;
    rdfs:isDefinedBy test: ;
    rdfs:subClassOf ast:Node ;
    test:isSupertype true ;
    test:nodeTypeId 17 .

test: a owl:Ontology ;
    rdfs:label "Test Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for test" ;
    owl:versionInfo "v0.25" ;
    test:abiVersion 14 ;
    test:fieldCount 3 ;
    test:languageName "None" ;
    test:nodeKindCount 29 .

