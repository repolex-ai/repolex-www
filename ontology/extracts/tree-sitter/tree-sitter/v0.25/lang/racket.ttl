    rdfs:label "program" ;
    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 48 .

racket:quasiquote a owl:Class ;
    rdfs:label "quasiquote" ;
    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 67 .

racket:quasisyntax a owl:Class ;
    rdfs:label "quasisyntax" ;
    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 69 .

racket:quote a owl:Class ;
    rdfs:label "quote" ;
    rdfs:isDefinedBy racket: ;
