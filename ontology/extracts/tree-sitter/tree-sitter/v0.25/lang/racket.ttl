    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 62 .

racket: a owl:Ontology ;
    rdfs:label "Racket Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for racket" ;
    owl:versionInfo "v0.25" ;
    racket:abiVersion 14 ;
    racket:fieldCount 0 ;
    racket:languageName "None" ;
    racket:nodeKindCount 80 .

