    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 58 .

racket:sexp_comment a owl:Class ;
    rdfs:label "sexp_comment" ;
    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 53 .

racket:string a owl:Class ;
    rdfs:label "string" ;
    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 55 .

racket:structure a owl:Class ;
    rdfs:label "structure" ;
    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 63 .

racket:symbol a owl:Class ;
