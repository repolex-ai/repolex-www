    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 70 .

racket:unquote_splicing a owl:Class ;
    rdfs:label "unquote_splicing" ;
    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 71 .

racket:unsyntax a owl:Class ;
    rdfs:label "unsyntax" ;
    rdfs:isDefinedBy racket: ;
    rdfs:subClassOf ast:Node ;
    racket:isSupertype true ;
    racket:nodeTypeId 72 .

racket:unsyntax_splicing a owl:Class ;
