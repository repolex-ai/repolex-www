@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rst: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/rst/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

rst:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

rst:arguments a owl:Class ;
    rdfs:label "arguments" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 111 .

rst:attribution a owl:Class ;
    rdfs:label "attribution" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 78 .

rst:block_quote a owl:Class ;
    rdfs:label "block_quote" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 77 .

