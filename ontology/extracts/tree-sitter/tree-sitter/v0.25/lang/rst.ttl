    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 74 .

rst:link a owl:Class,
        owl:DatatypeProperty ;
    rdfs:label "link",
        "link (literal)" ;
    rdfs:comment "Literal value for link field when it contains a terminal node" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:fieldId 2 ;
    rst:isSupertype true ;
    rst:isTerminalField true ;
    rst:nodeTypeId 2 .

rst:list_item a owl:Class ;
    rdfs:label "list_item" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 64,
        66,
        68 .

