    rst:nodeTypeId 50,
        90 .

rst:content a owl:Class ;
    rdfs:label "content" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 113 .

rst:definition a owl:Class ;
