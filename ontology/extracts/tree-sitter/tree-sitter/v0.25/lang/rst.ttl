    rst:isSupertype true ;
    rst:nodeTypeId 79 .

rst:document a owl:Class ;
    rdfs:label "document" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 52 .

rst:emphasis a owl:Class ;
    rdfs:label "emphasis" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
