    rdfs:label "literal" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 36 .

rst:literal_block a owl:Class ;
    rdfs:label "literal_block" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 25 .

rst:name a owl:Class,
        owl:DatatypeProperty ;
    rdfs:label "name",
        "name (literal)" ;
    rdfs:comment "Literal value for name field when it contains a terminal node" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:fieldId 3 ;
    rst:isSupertype true ;
    rst:isTerminalField true ;
    rst:nodeTypeId 46 .

rst:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

rst:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

