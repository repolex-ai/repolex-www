    rdfs:label "footnote" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 82 .

rst:footnote_reference a owl:Class ;
    rdfs:label "footnote_reference" ;
    rdfs:isDefinedBy rst: ;
    rdfs:subClassOf ast:Node ;
    rst:isSupertype true ;
    rst:nodeTypeId 39 .

rst:inline_target a owl:Class ;
    rdfs:label "inline_target" ;
    rdfs:isDefinedBy rst: ;
