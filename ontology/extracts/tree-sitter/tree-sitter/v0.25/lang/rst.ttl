rst: a owl:Ontology ;
    rdfs:label "Rst Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for rst" ;
    owl:versionInfo "v0.25" ;
    rst:abiVersion 14 ;
    rst:fieldCount 3 ;
    rst:languageName "None" ;
    rst:nodeKindCount 120 .

