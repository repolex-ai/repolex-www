@prefix ast: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qmldir: <https://repolex.ai/ontology/extracts/tree-sitter/tree-sitter/v0.25/lang/qmldir/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

qmldir:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

qmldir:command a owl:Class ;
    rdfs:label "command" ;
    rdfs:isDefinedBy qmldir: ;
    rdfs:subClassOf ast:Node ;
    qmldir:isSupertype true ;
    qmldir:nodeTypeId 19 .

qmldir:comment a owl:Class ;
    rdfs:label "comment" ;
    rdfs:isDefinedBy qmldir: ;
    rdfs:subClassOf ast:Node ;
    qmldir:isSupertype true ;
    qmldir:nodeTypeId 17 .

qmldir:fieldCount a owl:AnnotationProperty ;
    rdfs:label "field count" ;
    rdfs:comment "Total number of fields in this grammar" .

qmldir:fieldId a owl:AnnotationProperty ;
    rdfs:label "field ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this field in this language" ;
    rdfs:domain rdf:Property ;
    rdfs:range xsd:nonNegativeInteger .

qmldir:float a owl:Class ;
    rdfs:label "float" ;
    rdfs:isDefinedBy qmldir: ;
    rdfs:subClassOf ast:Node ;
    qmldir:isSupertype true ;
    qmldir:nodeTypeId 16 .

qmldir:identifier a owl:Class ;
    rdfs:label "identifier" ;
    rdfs:isDefinedBy qmldir: ;
    rdfs:subClassOf ast:Node ;
    qmldir:isSupertype true ;
    qmldir:nodeTypeId 13 .

qmldir:isSupertype a owl:AnnotationProperty ;
    rdfs:label "is supertype" ;
    rdfs:comment "Whether this node type is a supertype in the grammar" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:boolean .

qmldir:isTerminalField a owl:AnnotationProperty ;
    rdfs:label "is terminal field" ;
    rdfs:comment "Whether this field points to terminal (leaf) nodes" ;
    rdfs:domain owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

qmldir:keyword a owl:Class ;
    rdfs:label "keyword" ;
    rdfs:isDefinedBy qmldir: ;
    rdfs:subClassOf ast:Node ;
    qmldir:isSupertype true ;
    qmldir:nodeTypeId 20 .

qmldir:languageName a owl:AnnotationProperty ;
    rdfs:label "language name" ;
    rdfs:comment "Name of the language as reported by tree-sitter" .

qmldir:module_definition a owl:Class ;
    rdfs:label "module_definition" ;
    rdfs:isDefinedBy qmldir: ;
    rdfs:subClassOf ast:Node ;
    qmldir:isSupertype true ;
    qmldir:nodeTypeId 18 .

qmldir:nodeKindCount a owl:AnnotationProperty ;
    rdfs:label "node kind count" ;
    rdfs:comment "Total number of node kinds in this grammar" .

qmldir:nodeTypeId a owl:AnnotationProperty ;
    rdfs:label "node type ID" ;
    rdfs:comment "Tree-sitter internal numeric ID for this node type in this language" ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:nonNegativeInteger .

qmldir:number a owl:Class ;
    rdfs:label "number" ;
    rdfs:isDefinedBy qmldir: ;
    rdfs:subClassOf ast:Node ;
    qmldir:isSupertype true ;
    qmldir:nodeTypeId 15 .

qmldir:unit a owl:Class ;
    rdfs:label "unit" ;
    rdfs:isDefinedBy qmldir: ;
    rdfs:subClassOf ast:Node ;
    qmldir:isSupertype true ;
    qmldir:nodeTypeId 14 .

qmldir: a owl:Ontology ;
    rdfs:label "Qmldir Grammar Ontology" ;
    rdfs:comment "Tree-sitter grammar ontology for qmldir" ;
    owl:versionInfo "v0.25" ;
    qmldir:abiVersion 14 ;
    qmldir:fieldCount 0 ;
    qmldir:languageName "None" ;
    qmldir:nodeKindCount 23 .

