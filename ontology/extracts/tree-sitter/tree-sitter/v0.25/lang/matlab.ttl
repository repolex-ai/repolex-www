matlab:_expression a owl:Class ;
    rdfs:label "_expression" ;
    rdfs:isDefinedBy matlab: ;
    rdfs:subClassOf ast:Node ;
    matlab:isSupertype true ;
    matlab:nodeTypeId 227 .

matlab:abiVersion a owl:AnnotationProperty ;
    rdfs:label "ABI version" ;
    rdfs:comment "Tree-sitter ABI version used by this grammar" .

matlab:argument a owl:DatatypeProperty ;
